# ============================================================
# whale-datacloud unified environment template
# All runtime environment variables use the DATACLOUD_ prefix.
# Copy only the variables you need into the target module's .env file.
# ============================================================


# ============================================================
# A. Shared database settings
# ============================================================
DATACLOUD_DB_URL=jdbc:postgresql://localhost:2703/postgres?currentSchema=byai&characterEncoding=utf8&serverTimezone=Asia/Shanghai&timeZone=GMT+8
DATACLOUD_DB_USER=postgres
DATACLOUD_DB_PASSWORD=


# ============================================================
# B. Shared LLM settings
# ============================================================
DATACLOUD_LLM_API_BASE=https://your-llm-proxy/v1
DATACLOUD_LLM_API_KEY=
DATACLOUD_LLM_MODEL=
DATACLOUD_LLM_TEMPERATURE=0.0


# ============================================================
# C. datacloud-analysis / backend settings
# ============================================================
DATACLOUD_AGENT_LOCALE=zh_CN
DATACLOUD_GATEWAY_REDIS_HOST=127.0.0.1
DATACLOUD_GATEWAY_REDIS_PORT=6379
DATACLOUD_GATEWAY_REDIS_USERNAME=
DATACLOUD_GATEWAY_REDIS_PASSWORD=
DATACLOUD_GATEWAY_REDIS_DB=0
DATACLOUD_GATEWAY_WORKER_ID=datacloud
DATACLOUD_GATEWAY_CONSUMER_GROUP=datacloud
DATACLOUD_GATEWAY_WORKSPACE_DIR=/tmp/datacloud
DATACLOUD_ONTOLOGY_LOAD_MODE=unified_interface
DATACLOUD_DISABLE_SSL_VERIFY=false
DATACLOUD_DISABLE_ASK_USER_TOOL=1
DATACLOUD_COMMAND_PLUGIN_DIRS=
DATACLOUD_TOOL_HOOK_PLUGIN_DIRS=
DATACLOUD_TOOL_PLUGIN_STRICT=false
DATACLOUD_REACT_MAX_ROUNDS=10
DATACLOUD_OUTPUT_FORMAT=markdown
DATACLOUD_TRACE_USER_QUERY=false
# 数字员工配置
DATACLOUD_MID_FTP_PATH=./resource/agents
# 是否开启意图澄清 wrapper 0 不开启 1 开启
DATACLOUD_ENABLE_PARADIGM_WRAPPER=0
DATACLOUD_HISTORY_MESSAGE_LIMIT=6

BE_DOMAINNAME_URL=http://xxxx:8888


# ============================================================
# D. datacloud-data service settings
# ============================================================
DATACLOUD_ONTOLOGY_PATH=
DATACLOUD_CSV_BASE_DIR=./tmp/csv
DATACLOUD_QUERY_RESULT_CSV_THRESHOLD=5
DATACLOUD_QUERY_RESULT_PREVIEW_ROWS=5
DATACLOUD_API_BASE_URL=http://127.0.0.1:8080
DATACLOUD_MAX_PLAN_RETRIES=2
DATACLOUD_SQL_EXECUTION_MODE=internal
DATACLOUD_TRACE_LOG_PATH=logs/query_trace.log
DATACLOUD_TRACE_ENABLED=false
DATACLOUD_ZNT_SERVER=
DATACLOUD_TERM_LOADER_TYPE=kb
DATACLOUD_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATACLOUD_INCLUDE_PLAN_IN_RESPONSE=true


# ============================================================
# E. datacloud-knowledge settings
# ============================================================
DATACLOUD_KNOWLEDGE_IMPORT_BATCH_SIZE=2000
DATACLOUD_DB_CONNECT_TIMEOUT=30
DATACLOUD_DB_LOCK_TIMEOUT_MS=
DATACLOUD_KNOWLEDGE_SNOWFLAKE_DATACENTER_ID=1
DATACLOUD_KNOWLEDGE_SNOWFLAKE_WORKER_ID=1
DATACLOUD_KNOWLEDGE_CACHE_DIR=
DATACLOUD_INTENT_ENABLE_VECTOR=0
DATACLOUD_KNOWLEDGE_BACKFILL_BATCH_SIZE=1000

# Embedding
DATACLOUD_EMBEDDING_API_BASE=
DATACLOUD_EMBEDDING_API_KEY=
DATACLOUD_EMBEDDING_MODEL=
DATACLOUD_EMBEDDING_BATCH_SIZE=10
DATACLOUD_EMBEDDING_DIMS=1024

# File store
DATACLOUD_FILE_STORAGE_DRIVER=
DATACLOUD_FILE_PUBLIC_BASE_URL=http://127.0.0.1:8000
DATACLOUD_FILE_DOWNLOAD_PATH_PREFIX=/files
DATACLOUD_FILE_DEFAULT_DIRECTORY=default
DATACLOUD_FILE_LOCAL_ROOT=./.datacloud_files
DATACLOUD_FILE_S3_BUCKET=
DATACLOUD_FILE_S3_ENDPOINT_URL=
DATACLOUD_FILE_S3_REGION=
DATACLOUD_FILE_S3_ACCESS_KEY_ID=
DATACLOUD_FILE_S3_SECRET_ACCESS_KEY=


# ============================================================
# F. Demo / local development extras
# ============================================================
DATACLOUD_NOTICE_URL=
DATACLOUD_REDIS_URL=
DATACLOUD_REDIS_HOST=127.0.0.1
DATACLOUD_REDIS_PORT=6379
DATACLOUD_REDIS_DB=0
DATACLOUD_REDIS_PASSWORD=
DATACLOUD_TODO_SCHEMA=crm_demo


# ============================================================
# G. Test-only settings
# ============================================================
DATACLOUD_ENABLE_INTEGRATION_TESTS=0
DATACLOUD_ALLOW_DROP_CREATE=0
DATACLOUD_TEST_DATABASE_DSN=
