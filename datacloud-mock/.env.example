# PostgreSQL 连接串（支持 postgresql:// 或 postgresql+asyncpg://）
# 若使用 postgresql://，启动时会自动替换为 postgresql+asyncpg://
DATABASE_URL=postgresql://gaussdb:OpenGauss@123@10.10.196.92:2703/crm_demo


# 可选：打印 SQL 日志，用于调试
# SQL_ECHO=false

# 通知接口（可选，未配置则不发送）
NOTICE_URL=http://10.10.165.31:8559/conversationService/open/api/notice/create


# Redis（用于 user_code -> user_id 映射，与 todo.py 一致）
REDIS_URL=redis://localhost:6379/0
