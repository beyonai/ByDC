      "function_name": "MySQL通用查询",
      "function_type": "API",
      "api_schema": {
        "openapi": "3.0.3",
        "info": {
          "title": "MySQL通用查询",
          "version": "1.0.0"
        },
        "servers": [
          { "url": "http://data-service:8082" }
        ],
        "paths": {
          "/api/v1/query": {
            "post": {
              "summary": "执行MySQL查询",
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "required": ["sql", "datasource_id"],
                      "properties": {
                        "sql": {
                          "type": "string",
                          "description": "SQL语句"
                        },
                        "datasource_id": {
                          "type": "string",
                          "description": "数据源ID"
                        },
                        "sql_param_emp_no": {
                          "type": "string",
                          "description": "动态参数：员工工号"
                        },
                        "sql_param_org_id": {
                          "type": "string",
                          "description": "动态参数：组织ID"
                        },
                        "sql_param_date_from": {
                          "type": "string",
                          "format": "date",
                          "description": "动态参数：开始日期"
                        },
                        "sql_param_date_to": {
                          "type": "string",
                          "format": "date",
                          "description": "动态参数：结束日期"
                        },
                        "sql_param_keyword": {
                          "type": "string",
                          "description": "动态参数：关键词"
                        }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "查询结果",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "result_set": {
                            "type": "array",
                            "items": { "type": "object" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
