# =============================================================
# datacloud-knowledge 环境变量模板
# 复制为 .env 并填入真实值，.env 已加入 .gitignore 不会提交
# =============================================================

# ── 数据库连接（PostgreSQL / OpenGauss）─────────────────────
DATACLOUD_DB_URL=jdbc:opengauss://127.0.0.1:5432/postgres?currentSchema=whale_datacloud
DATACLOUD_DB_USER=gaussdb
DATACLOUD_DB_PASSWORD=your_password_here

# ── 集成测试开关 ──────────────────────────────────────────────
# 设为 1 才会运行需要真实数据库的集成测试，留空则自动 skip
DATACLOUD_ENABLE_INTEGRATION_TESTS=
