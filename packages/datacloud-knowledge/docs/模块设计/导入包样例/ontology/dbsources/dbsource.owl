<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/database/ontology#">
         
    <!-- 类定义 -->
    <owl:Class rdf:about="#DatabaseDefinition">
        <rdfs:label>数据源信息定义</rdfs:label>
    </owl:Class>
    
    <!-- 具体的数据库实例 -->
    <owl:NamedIndividual rdf:about="#database_baiyingshujuku">
        <rdf:type rdf:resource="#DatabaseDefinition"/>
        <dbCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">baiyingshujuku</dbCode>
        <dbType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">gaussdb</dbType>
        <dbParams rdf:datatype="http://www.w3.org/2001/XMLSchema#string">
[{"paramName":"url","paramValue":"jdbc:postgresql://10.10.196.92:2703/postgres?gssEncMode\u003ddisable\u0026reWriteBatchedInserts\u003dtrue"},{"paramName":"schemaCode","paramValue":"byai"},{"paramName":"username","paramValue":"gaussdb"},{"paramName":"encoding","paramValue":"UTF8"},{"paramName":"password","paramValue":"${passcode}"}]</dbParams>
    </owl:NamedIndividual>
    
    <!-- 属性定义 -->
    <owl:DatatypeProperty rdf:about="#dbCode">
        <rdfs:domain rdf:resource="#DatabaseDefinition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#dbType">
        <rdfs:domain rdf:resource="#DatabaseDefinition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#dbParams">
        <rdfs:domain rdf:resource="#DatabaseDefinition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
</rdf:RDF>