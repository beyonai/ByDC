{
  "function_code": "fn_todo_approve",
  "function_name": "审批待办",
  "description": "批量审批待办事项（通过或拒绝）",
  "function_type": "API",
  "api_schema": {
    "openapi": "3.0.3",
    "info": {
      "title": "审批待办",
      "version": "1.0.0"
    },
    "servers": [
      {
        "url": "http://127.0.0.1:8001"
      }
    ],
    "paths": {
      "/api/v1/todos/batch/approve": {
        "post": {
          "summary": "批量审批待办",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "approvalComment": {
                      "type": "string",
                      "description": "审批意见"
                    },
                    "approvalStatus": {
                      "type": "string",
                      "description": "审批状态：Approving(通过) 或 Rejected(拒绝)",
                      "enum": [
                        "Approving",
                        "Rejected"
                      ]
                    },
                    "todoIds": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "待办ID列表"
                    }
                  },
                  "required": [
                    "approvalStatus",
                    "todoIds"
                  ]
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "审批结果",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "todoId": {
                        "type": "string"
                      },
                      "approvalStatus": {
                        "type": "string",
                        "description": "审批状态：Approving(通过) 或 Rejected(拒绝)"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}