{
  "function_code": "fn_expense_query",
  "function_name": "查询费用报备",
  "description": "查询费用报备列表，支持多种过滤条件",
  "function_type": "API",
  "api_schema": {
    "openapi": "3.0.3",
    "info": {
      "title": "查询费用报备",
      "version": "1.0.0"
    },
    "servers": [
      {
        "url": "http://127.0.0.1:8001"
      }
    ],
    "paths": {
      "/api/v1/expense-reports/list": {
        "post": {
          "summary": "查询费用报备列表",
          "requestBody": {
            "required": false,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "applicantEmpNos": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "申请人工号列表"
                    },
                    "applicantOrgId": {
                      "type": "string",
                      "description": "申请组织ID"
                    },
                    "approvalStatus": {
                      "type": "string",
                      "description": "审批状态"
                    },
                    "applyTimeStart": {
                      "type": "string",
                      "description": "申请时间起，格式yyyy-MM-dd HH:mm:ss"
                    },
                    "applyTimeEnd": {
                      "type": "string",
                      "description": "申请时间止，格式yyyy-MM-dd HH:mm:ss"
                    },
                    "page": {
                      "type": "integer",
                      "description": "页码"
                    },
                    "pageSize": {
                      "type": "integer",
                      "description": "每页条数"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "费用报备列表",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "expenseReports": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string"
                            },
                            "applicantEmpNo": {
                              "type": "string"
                            },
                            "applicantName": {
                              "type": "string"
                            },
                            "applicantOrgId": {
                              "type": "string"
                            },
                            "expenseAmount": {
                              "type": "number"
                            },
                            "expenseDesc": {
                              "type": "string"
                            },
                            "relatedBoId": {
                              "type": "string"
                            },
                            "relatedCustomerId": {
                              "type": "string"
                            },
                            "applyTime": {
                              "type": "string"
                            },
                            "approvalStatus": {
                              "type": "string"
                            },
                            "approvalComment": {
                              "type": "string"
                            },
                            "approvedAt": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}