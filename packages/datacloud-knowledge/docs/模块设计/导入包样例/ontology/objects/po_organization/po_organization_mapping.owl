<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/ontology#">
         
    <!-- 类定义 -->
    <owl:Class rdf:about="#EntityMapping">
        <rdfs:label>实体映射</rdfs:label>
    </owl:Class>
    
    <owl:Class rdf:about="#Mapping">
        <rdfs:label>映射关系</rdfs:label>
    </owl:Class>
    
    <!-- 具体的实体映射实例 -->
    <owl:NamedIndividual rdf:about="#po_organization_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">po_organization</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">组织信息</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">主数据系统组织对象，包含组织层级、编码、类型等信息</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#orgId_mapping"/>
    </owl:NamedIndividual>
    
    <!-- 映射实例 -->
    <owl:NamedIndividual rdf:about="#orgId_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">orgId</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">组织ID</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tab_or</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">org_id</source_column_code>
        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hive154</source_datasource_code>
    </owl:NamedIndividual>
    
    <!-- 属性定义 -->
    <owl:DatatypeProperty rdf:about="#entity_code">
        <rdfs:domain rdf:resource="#EntityMapping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#entity_name">
        <rdfs:domain rdf:resource="#EntityMapping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#entity_desc">
        <rdfs:domain rdf:resource="#EntityMapping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#version">
        <rdfs:domain rdf:resource="#EntityMapping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#mapping">
        <rdfs:domain rdf:resource="#EntityMapping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <!-- 映射属性定义 -->
    <owl:DatatypeProperty rdf:about="#property_code">
        <rdfs:domain rdf:resource="#Mapping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#property_name">
        <rdfs:domain rdf:resource="#Mapping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#source_table_code">
        <rdfs:domain rdf:resource="#Mapping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    
    <owl:DatatypeProperty rdf:about="#source_column_code">
        <rdfs:domain rdf:resource="#Mapping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#source_datasource_code">
        <rdfs:domain rdf:resource="#Mapping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
</rdf:RDF>