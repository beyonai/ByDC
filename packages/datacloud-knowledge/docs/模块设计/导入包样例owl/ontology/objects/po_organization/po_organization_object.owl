<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/ontology#">
         
    <!-- 类定义 -->
    <owl:Class rdf:about="#EntityDefinition">
        <rdfs:label>实体定义</rdfs:label>
    </owl:Class>
    
    <!-- 具体的实体实例 -->
    <owl:NamedIndividual rdf:about="#po_organization_v2">
        <rdf:type rdf:resource="#EntityDefinition"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">po_organization</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">组织信息</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">主数据系统组织对象，包含组织层级、编码、类型等信息</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <fields rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[{ "property_code": "orgId", "property_name": "组织ID", "data_type": "BIGINT", "is_required": true, "default_value": "", "source_column": "org_id", "synonyms": "同义词", "data_format": "数据格式（如：yyyy-MM-dd、#,##0.00等）", "ext_field": "", "property_category":"分类（属性、度量、指标、标签）", "property_group": "存储属性" }, { "property_code": "age", "property_name": "年龄", "data_type": "INT", "is_required": true, "default_value": "", "source_column": "org_id", "synonyms": "同义词", "data_format": "数据格式（如：yyyy-MM-dd、#,##0.00等）", "ext_field": "", "property_category":"分类（属性、度量、指标、标签）", "property_group": "计算属性", "rel_function": ["compute_age_fun"] }]</fields>
        <action_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">["query_org_by_name_or_id"]</action_refs>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">["rel_po_organization_po_organization_1"]</relations>
    </owl:NamedIndividual>
    
    <!-- 属性定义 -->
    <owl:DatatypeProperty rdf:about="#entity_code">
        <rdfs:domain rdf:resource="#EntityDefinition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#entity_name">
        <rdfs:domain rdf:resource="#EntityDefinition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#entity_desc">
        <rdfs:domain rdf:resource="#EntityDefinition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#version">
        <rdfs:domain rdf:resource="#EntityDefinition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#fields">
        <rdfs:domain rdf:resource="#EntityDefinition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#action_refs">
        <rdfs:domain rdf:resource="#EntityDefinition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
    <owl:DatatypeProperty rdf:about="#relations">
        <rdfs:domain rdf:resource="#EntityDefinition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    
</rdf:RDF>