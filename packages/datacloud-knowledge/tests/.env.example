# PostgreSQL 连接方式二选一：
# 方式1：分项配置（推荐，密码含 @# 等特殊字符时无解析问题）
DB_HOST=10.10.179.2
DB_PORT=5432
DB_USER=gaussdb
DB_PASSWORD=Admin@123
DB_NAME=postgres

# 方式2：连接串（若使用 postgresql://，会自动替换为 postgresql+asyncpg://）
# DATABASE_URL=postgresql://gaussdb:OpenGauss%40123@10.10.196.92:2703/crm_demo


# 可选：打印 SQL 日志，用于调试
# SQL_ECHO=false

