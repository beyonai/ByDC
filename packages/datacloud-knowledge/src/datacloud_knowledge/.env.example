# ============================================================
# DataCloud Knowledge - File Store (.env.example)
#
# 说明：
# - 环境变量前缀：FILE_
# - download_url 返回形式：
#   {FILE_PUBLIC_BASE_URL}{FILE_DOWNLOAD_PATH_PREFIX}/{directory}/{md5}
# - directory 为“物理目录前缀”，上传时可指定；不指定则用 FILE_DEFAULT_DIRECTORY
# ============================================================

# ---------------------------
# 通用配置
# ---------------------------

# 存储驱动：local | s3
# 不填时：若 S3 必填项齐全则走 s3，否则走 local
FILE_STORAGE_DRIVER=S3

# download_url 拼接
FILE_PUBLIC_BASE_URL=http://127.0.0.1:8000
FILE_DOWNLOAD_PATH_PREFIX=/files

# 上传未指定 directory 时使用
FILE_DEFAULT_DIRECTORY=default

# ---------------------------
# Local 后端（FILE_STORAGE_DRIVER=local 或默认走 local 时）
# ---------------------------

# 本地存储根目录（会在其下创建 index/ 与 {directory}/objects/、{directory}/refs/）
FILE_LOCAL_ROOT=./.datacloud_files

# ---------------------------
# S3 兼容后端（MinIO/第三方对象存储）
# FILE_STORAGE_DRIVER=s3 或 S3 配置齐全时启用
# ---------------------------

# 必填：桶名
FILE_S3_BUCKET=dc-files

# MinIO/私有云常用：endpoint（公有云 S3 兼容服务可能不需要）
FILE_S3_ENDPOINT_URL=http://10.10.196.92:2704

# 可选：region
# FILE_S3_REGION=us-east-1

# 必填：AK/SK
FILE_S3_ACCESS_KEY_ID=minioadmin
FILE_S3_SECRET_ACCESS_KEY=minioadmin

