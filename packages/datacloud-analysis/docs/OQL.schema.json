{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OQL Protocol Schema",
  "description": "本体查询语言(OQL)协议的完整JSON Schema定义，用于LLM生成结构化本体操作指令",
  "oneOf": [
    {
      "$ref": "#/definitions/SingleToolCall",
      "description": "单步工具调用"
    },
    {
      "$ref": "#/definitions/Pipeline",
      "description": "多步链式Pipeline"
    }
  ],
  "definitions": {
    "SingleToolCall": {
      "type": "object",
      "required": ["tool", "parameters"],
      "properties": {
        "tool": {
          "type": "string",
          "enum": ["QueryObjects", "ExecuteAction"],
          "description": "工具名称"
        },
        "parameters": {
          "description": "工具参数，类型由tool字段决定"
        }
      },
      "oneOf": [
        {
          "properties": {
            "tool": { "const": "QueryObjects" },
            "parameters": { "$ref": "#/definitions/QueryObjectsParameters" }
          }
        },
        {
          "properties": {
            "tool": { "const": "ExecuteAction" },
            "parameters": { "$ref": "#/definitions/ExecuteActionParameters" }
          }
        }
      ]
    },
    "Pipeline": {
      "type": "array",
      "minItems": 2,
      "maxItems": 10,
      "items": {
        "$ref": "#/definitions/PipelineStep"
      },
      "description": "多步链式执行，后续步骤可通过$ref引用前序步骤结果"
    },
    "PipelineStep": {
      "type": "object",
      "required": ["step_id", "tool", "parameters"],
      "properties": {
        "step_id": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$",
          "description": "步骤ID，在Pipeline内唯一，供$ref引用"
        },
        "tool": {
          "type": "string",
          "enum": ["QueryObjects", "ExecuteAction"]
        },
        "parameters": {
          "description": "工具参数，参数值中可使用$ref引用前序步骤结果"
        }
      }
    },
    "QueryObjectsParameters": {
      "type": "object",
      "required": ["object_type"],
      "properties": {
        "object_type": {
          "type": "string",
          "description": "对象类型名或视图名（必须来自本体注册表）"
        },
        "select": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "返回属性列表，省略则返回全部非计算属性"
        },
        "where": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Condition"
          },
          "description": "行级过滤条件数组，数组根节点条件间默认AND"
        },
        "include_links": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/LinkClause"
          },
          "description": "关系漫游数组（仅DB主对象支持，聚合模式禁用）"
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Metric"
          },
          "description": "聚合指标数组，有此字段则触发聚合模式"
        },
        "group_by": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GroupByClause"
          },
          "description": "分组维度数组（聚合模式使用）"
        },
        "having": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Condition"
          },
          "description": "聚合后过滤，field引用metrics中的name"
        },
        "order_by": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/OrderByClause"
          },
          "description": "排序数组"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "default": 100,
          "description": "返回行数上限（列表模式默认100，聚合模式默认1000）"
        },
        "offset": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "分页偏移量（仅列表模式）"
        }
      }
    },
    "ExecuteActionParameters": {
      "type": "object",
      "required": ["action_type"],
      "properties": {
        "action_type": {
          "type": "string",
          "description": "本体中注册的动作名（与本体注册名保持一致）"
        },
        "target_objects": {
          "oneOf": [
            {
              "type": "array",
              "items": { "type": "string" },
              "description": "动作作用的实体主键ID列表"
            },
            {
              "$ref": "#/definitions/RefExpression"
            }
          ],
          "description": "动作作用的实体主键ID列表；对象级动作必填，全局动作可省略"
        },
        "payload": {
          "type": "object",
          "description": "动作所需的业务参数，由本体动作注册表的Schema定义必填项和类型"
        }
      }
    },
    "Condition": {
      "oneOf": [
        {
          "$ref": "#/definitions/SimpleCondition"
        },
        {
          "$ref": "#/definitions/LogicCondition"
        }
      ]
    },
    "SimpleCondition": {
      "type": "object",
      "required": ["field", "op", "value"],
      "properties": {
        "field": {
          "type": "string",
          "description": "属性名（必须来自本体注册表）"
        },
        "op": {
          "type": "string",
          "enum": ["eq", "ne", "gt", "gte", "lt", "lte", "in", "nin", "like", "isNull", "between", "relativeDate"],
          "description": "操作符"
        },
        "value": {
          "description": "比较值，类型取决于操作符"
        }
      },
      "additionalProperties": false
    },
    "LogicCondition": {
      "type": "object",
      "required": ["logic"],
      "properties": {
        "logic": {
          "type": "string",
          "enum": ["or", "not"],
          "description": "逻辑操作符"
        },
        "conditions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Condition"
          },
          "minItems": 2,
          "description": "OR条件数组（logic为or时使用）"
        },
        "condition": {
          "$ref": "#/definitions/Condition",
          "description": "NOT条件（logic为not时使用）"
        }
      },
      "oneOf": [
        {
          "properties": {
            "logic": { "const": "or" }
          },
          "required": ["conditions"]
        },
        {
          "properties": {
            "logic": { "const": "not" }
          },
          "required": ["condition"]
        }
      ]
    },
    "LinkClause": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^[^.]+(?:\\.[^.]+){0,4}$",
          "description": "关系路径，单跳直接写关系名，多跳用.连接，最大5跳"
        },
        "select": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "该跳对象返回的属性列表，省略则返回全部非计算属性"
        }
      },
      "additionalProperties": false
    },
    "Metric": {
      "type": "object",
      "required": ["name", "op"],
      "properties": {
        "name": {
          "type": "string",
          "description": "指标别名，用于order_by/having引用"
        },
        "op": {
          "type": "string",
          "enum": ["count", "count_distinct", "sum", "avg", "max", "min"],
          "description": "聚合函数"
        },
        "field": {
          "type": "string",
          "description": "聚合字段名（count可省略）"
        }
      },
      "additionalProperties": false
    },
    "GroupByClause": {
      "type": "object",
      "required": ["field"],
      "properties": {
        "field": {
          "type": "string",
          "description": "分组字段名"
        },
        "granularity": {
          "type": "string",
          "enum": ["day", "week", "month", "quarter", "year"],
          "description": "时间粒度（仅时间字段可用）"
        }
      },
      "additionalProperties": false
    },
    "OrderByClause": {
      "type": "object",
      "required": ["field"],
      "properties": {
        "field": {
          "type": "string",
          "description": "排序字段名（列表模式为属性名，聚合模式可引用metrics中的name）"
        },
        "direction": {
          "type": "string",
          "enum": ["asc", "desc"],
          "default": "asc",
          "description": "排序方向"
        }
      },
      "additionalProperties": false
    },
    "RefExpression": {
      "type": "object",
      "required": ["$ref"],
      "properties": {
        "$ref": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_]*\\.result\\[(\\*|\\d+)\\]\\.[^.]+$",
          "description": "引用语法：{step_id}.result[*|N].{field}"
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "description": "单步查询示例：查询延误航班",
      "value": {
        "tool": "QueryObjects",
        "parameters": {
          "object_type": "航班",
          "select": ["航班号", "航空公司", "延误时长"],
          "where": [
            { "field": "状态", "op": "eq", "value": "延误" },
            { "field": "起飞时间", "op": "relativeDate", "value": "today" }
          ],
          "order_by": [{ "field": "延误时长", "direction": "desc" }],
          "limit": 10
        }
      }
    },
    {
      "description": "聚合查询示例：按航空公司统计延误",
      "value": {
        "tool": "QueryObjects",
        "parameters": {
          "object_type": "航班",
          "metrics": [
            { "name": "延误数", "op": "count" },
            { "name": "平均延误时长", "op": "avg", "field": "延误时长" }
          ],
          "group_by": [{ "field": "航空公司" }],
          "where": [
            { "field": "状态", "op": "eq", "value": "延误" }
          ],
          "order_by": [{ "field": "延误数", "direction": "desc" }]
        }
      }
    },
    {
      "description": "Pipeline示例：查询延误航班并发送通知",
      "value": [
        {
          "step_id": "s1",
          "tool": "QueryObjects",
          "parameters": {
            "object_type": "航班",
            "select": ["航班号", "延误时长"],
            "where": [
              { "field": "状态", "op": "eq", "value": "延误" },
              { "field": "延误时长", "op": "gt", "value": 120 }
            ],
            "limit": 10
          }
        },
        {
          "step_id": "s2",
          "tool": "ExecuteAction",
          "parameters": {
            "action_type": "发送延误通知",
            "target_objects": { "$ref": "s1.result[*].航班号" },
            "payload": {
              "通知类型": "短信",
              "模板": "延误致歉"
            }
          }
        }
      ]
    }
  ]
}
