# DataCloud Data Service 配置示例
# 复制为 .env 并按需修改: cp .env.example .env

# ========== LLM（自然语言转 SQL，不配置则 NL2SQL 不可用）==========
DC_LLM_API_KEY=sk-xxx
DC_LLM_BASE_URL=https://lab.iwhalecloud.com/gpt-proxy/v1
# DC_LLM_API_KEY=sk-xxx
# DC_LLM_BASE_URL=https://apis.iflow.cn/v1
DC_LLM_MODEL=Qwen/Qwen3-Coder-30B-Instruct
# DC_LLM_MODEL=MiniMax-M2.5
DC_LLM_TEMPERATURE=0.0

# ========== 本体与场景 ==========
DC_ONTOLOGY_PATH=../../examples/e_commerce_demo/mock_env/resource/knowledge/import_package/ontology/e_commerce_scene_01_data_analysis_full.json
DC_SCENE_PATH=../../examples/e_commerce_demo/mock_env/resource/knowledge/import_package/ontology/e_commerce_scene_01_data_analysis_full.json

# ========== 数据源 ==========
# 数据源配置来自本体对象上的 source_config，无需单独配置 YAML

# ========== 其他 ==========
# CSV 临时文件目录，默认当前目录下的 tmp
DC_CSV_BASE_DIR=./tmp/csv
DC_MAX_PLAN_RETRIES=2
# SQL 执行模式: internal=内置 SqlExecutor, external=HTTP 调外部 SQL 服务
DC_SQL_EXECUTION_MODE=internal

# DC_ZNT_SERVER=https://byai.iwhalecloud.com/developer/knowledgeService

DC_TRACE_ENABLED=false

# ========== 术语服务（termMeta 加载）==========
# API 模式（znt_server）
# DC_ZNT_SERVER=https://your-term-server

# KB（knowledge_search）模式 — 术语从知识库数据库读取
DC_TERM_LOADER_TYPE=kb   # api | kb（默认 api）
# 知识库 PostgreSQL 连接（search_terms_by_type 依赖）
DB_HOST=10.10.179.2
DB_PORT=5432
DB_USER=gaussdb
DB_PASSWORD=Admin@123
DB_NAME=postgres
KNOWLEDGE_DB_TYPE=opengauss
KNOWLEDGE_SCHEMA=whale_datacloud