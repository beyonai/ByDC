# DataCloud Data Service 配置示例
# 复制为 .env 并按需修改: cp .env.example .env

# ========== LLM（自然语言转 SQL，不配置则 NL2SQL 不可用）==========
DATACLOUD_LLM_API_KEY=sk-xxx
DATACLOUD_LLM_API_BASE=https://lab.iwhalecloud.com/gpt-proxy/v1
DATACLOUD_LLM_MODEL=Qwen/Qwen3-Coder-30B-Instruct
DATACLOUD_LLM_TEMPERATURE=0.0

# ========== 本体与场景 ==========
DATACLOUD_ONTOLOGY_PATH=../../examples/e_commerce_demo/mock_env/resource/knowledge/import_package/ontology/e_commerce_scene_01_data_analysis_full.json
DATACLOUD_SCENE_PATH=../../examples/e_commerce_demo/mock_env/resource/knowledge/import_package/ontology/e_commerce_scene_01_data_analysis_full.json

# ========== 数据源 ==========
# 数据源配置来自本体对象上的 source_config，无需单独配置 YAML

# ========== 其他 ==========
# CSV 临时文件目录，默认当前目录下的 tmp
DATACLOUD_CSV_BASE_DIR=./tmp/csv
DATACLOUD_MAX_PLAN_RETRIES=2
# SQL 执行模式: internal=内置 SqlExecutor, external=HTTP 调外部 SQL 服务
DATACLOUD_SQL_EXECUTION_MODE=internal

DATACLOUD_TRACE_ENABLED=false

# ========== 术语服务（knowledge_search）==========
# 知识库 PostgreSQL 连接（search_terms_by_type 依赖）
DATACLOUD_DB_URL=jdbc:opengauss://10.10.179.2:5432/postgres?currentSchema=whale_datacloud
DATACLOUD_DB_USER=gaussdb
DATACLOUD_DB_PASSWORD=Admin@123
