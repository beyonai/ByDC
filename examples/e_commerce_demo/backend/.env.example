# =============================================================
# e_commerce_demo agent backend — 环境变量模板
# 使用方式：cp .env.example .env  然后填写真实值
# .env 文件已在 .gitignore 中忽略，请勿将真实密码提交到仓库。
# =============================================================


# -------------------------------------------------------------
# 一、会话管理 PG（OpenGauss / PostgreSQL）
# -------------------------------------------------------------
# DSN 格式：postgresql://用户名:密码@host:port/数据库名
# 注意：密码中含 @ 时需 URL 编码为 %40，含 # 时编码为 %23
DATACLOUD_PG_CHECKPOINT_URI=postgresql://gaussdb:YOUR_PASSWORD@DB_HOST:DB_PORT/DB_NAME
# 存放 LangGraph checkpoint 表的 schema（首次启动会自动建表）
DATACLOUD_PG_CHECKPOINT_SCHEMA=datacloud_agent_session


# -------------------------------------------------------------
# 二、数据查询服务（外部 HTTP API）
# -------------------------------------------------------------
DATACLOUD_DATA_SERVICE_BASE_URL=http://DATA_SERVICE_HOST:PORT
# Bearer token，对应请求头 Authorization: Bearer <token>
DATACLOUD_DATA_SERVICE_API_KEY=your-token
# 固定租户 ID，对应请求头 X-Tenant-Id
DATACLOUD_DATA_SERVICE_TENANT_ID=tenant-001
# 业务系统代码，对应请求头 X-System-Code
DATACLOUD_DATA_SERVICE_SYSTEM_CODE=crm
# 以下为可选覆盖，默认值已在代码中设定
# DATACLOUD_DATA_SERVICE_QUERY_PATH=/api/v1/query
# DATACLOUD_DATA_SERVICE_TIMEOUT=60


# -------------------------------------------------------------
# 三、工作空间路径（本地路径 or NFS 挂载点）
# -------------------------------------------------------------
DATACLOUD_WORKSPACE_PUBLIC_ROOT=/data/public/datacloud
DATACLOUD_WORKSPACE_PRIVATE_ROOT=/data/users
# 可选，不填则从 PRIVATE_ROOT 派生
# DATACLOUD_WORKSPACE_TASKS_ROOT=/data/tasks


# -------------------------------------------------------------
# 四、大模型 — 快速问答（DATACLOUD_LLM_QUICK_*）
# -------------------------------------------------------------
DATACLOUD_LLM_QUICK_API_BASE=https://YOUR_LLM_PROXY/v1
DATACLOUD_LLM_QUICK_API_KEY=sk-xxx
DATACLOUD_LLM_QUICK_MODEL=Qwen/Qwen3-8B
DATACLOUD_LLM_QUICK_TEMPERATURE=0.0


# -------------------------------------------------------------
# 五、大模型 — 编码（DATACLOUD_LLM_CODING_*）
# -------------------------------------------------------------
DATACLOUD_LLM_CODING_API_BASE=https://YOUR_LLM_PROXY/v1
DATACLOUD_LLM_CODING_API_KEY=sk-xxx
DATACLOUD_LLM_CODING_MODEL=Qwen/Qwen3-235B-A22B
DATACLOUD_LLM_CODING_TEMPERATURE=0.0


# -------------------------------------------------------------
# 六、大模型 — 推理（DATACLOUD_LLM_REASONING_*）
# -------------------------------------------------------------
DATACLOUD_LLM_REASONING_API_BASE=https://YOUR_LLM_PROXY/v1
DATACLOUD_LLM_REASONING_API_KEY=sk-xxx
DATACLOUD_LLM_REASONING_MODEL=Qwen/Qwen3-235B-A22B
DATACLOUD_LLM_REASONING_TEMPERATURE=0.0


# -------------------------------------------------------------
# 七、大模型 — 多模态（DATACLOUD_LLM_MULTIMODAL_*）
# -------------------------------------------------------------
DATACLOUD_LLM_MULTIMODAL_API_BASE=https://YOUR_LLM_PROXY/v1
DATACLOUD_LLM_MULTIMODAL_API_KEY=sk-xxx
DATACLOUD_LLM_MULTIMODAL_MODEL=Qwen/Qwen2-VL-72B-Instruct
DATACLOUD_LLM_MULTIMODAL_TEMPERATURE=0.0


# -------------------------------------------------------------
# 八、Embedding 小模型（DATACLOUD_EMBEDDING_*）
# -------------------------------------------------------------
DATACLOUD_EMBEDDING_API_BASE=https://YOUR_LLM_PROXY/v1
DATACLOUD_EMBEDDING_API_KEY=sk-xxx
DATACLOUD_EMBEDDING_MODEL=text-embedding-v3


# -------------------------------------------------------------
# 九、Gateway Worker（datacloud_service/main.py — Redis 与运行标识）
# -------------------------------------------------------------
# OpenAI 兼容网关（与 gateway_sdk run_worker 约定一致）
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://YOUR_LLM_PROXY/v1
DATACLOUD_GATEWAY_WORKER_ID=datacloud
DATACLOUD_GATEWAY_REDIS_HOST=127.0.0.1
DATACLOUD_GATEWAY_REDIS_PORT=6379
DATACLOUD_GATEWAY_REDIS_DB=0
# 无密码可留空或删除该行
DATACLOUD_GATEWAY_REDIS_PASSWORD=
DATACLOUD_GATEWAY_REDIS_USERNAME=
DATACLOUD_GATEWAY_CONSUMER_GROUP=datacloud
DATACLOUD_GATEWAY_WORKSPACE_DIR=/tmp/datacloud
