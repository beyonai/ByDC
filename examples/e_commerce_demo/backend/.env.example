# =============================================================
# e_commerce_demo agent backend — 环境变量模板
# 使用方式：cp .env.example .env  然后填写真实值
# .env 文件已在 .gitignore 中忽略，请勿将真实密码提交到仓库。
# =============================================================


# -------------------------------------------------------------
# 一、统一数据库（OpenGauss / PostgreSQL）
# -------------------------------------------------------------
# JDBC URL 中可通过 currentSchema 指定 checkpoint / 业务默认 schema
DATACLOUD_DB_URL=jdbc:postgresql://127.0.0.1:5432/postgres?currentSchema=datacloud_agent_session
DATACLOUD_DB_USER=gaussdb
DATACLOUD_DB_PASSWORD=YOUR_PASSWORD


# -------------------------------------------------------------
# 二、数据查询服务（外部 HTTP API）
# -------------------------------------------------------------
DATACLOUD_DATA_SERVICE_BASE_URL=http://DATA_SERVICE_HOST:PORT
# Bearer token，对应请求头 Authorization: Bearer <token>
DATACLOUD_DATA_SERVICE_API_KEY=your-token
# 固定租户 ID，对应请求头 X-Tenant-Id
DATACLOUD_DATA_SERVICE_TENANT_ID=tenant-001
# 业务系统代码，对应请求头 X-System-Code
DATACLOUD_DATA_SERVICE_SYSTEM_CODE=crm
# 以下为可选覆盖，默认值已在代码中设定
# DATACLOUD_DATA_SERVICE_QUERY_PATH=/api/v1/query
# DATACLOUD_DATA_SERVICE_TIMEOUT=60


# -------------------------------------------------------------
# 三、工作空间路径（本地路径 or NFS 挂载点）
# -------------------------------------------------------------
DATACLOUD_WORKSPACE_PUBLIC_ROOT=/data/public/datacloud
DATACLOUD_WORKSPACE_PRIVATE_ROOT=/data/users
# 可选，不填则从 PRIVATE_ROOT 派生
# DATACLOUD_WORKSPACE_TASKS_ROOT=/data/tasks


# -------------------------------------------------------------
# 四、大模型
# 所有 LLM 统一使用这一组配置
# -------------------------------------------------------------
DATACLOUD_LLM_API_BASE=https://YOUR_LLM_PROXY/v1
DATACLOUD_LLM_API_KEY=sk-xxx
DATACLOUD_LLM_MODEL=Qwen/Qwen3-235B-A22B
DATACLOUD_LLM_TEMPERATURE=0.0


# -------------------------------------------------------------
# 八、Embedding 小模型（DATACLOUD_EMBEDDING_*）
# -------------------------------------------------------------
DATACLOUD_EMBEDDING_API_BASE=https://YOUR_LLM_PROXY/v1
DATACLOUD_EMBEDDING_API_KEY=sk-xxx
DATACLOUD_EMBEDDING_MODEL=text-embedding-v3


# -------------------------------------------------------------
# 九、Gateway Worker（datacloud_service/main.py — Redis 与运行标识）
# -------------------------------------------------------------
DATACLOUD_GATEWAY_WORKER_ID=datacloud
DATACLOUD_GATEWAY_REDIS_HOST=127.0.0.1
DATACLOUD_GATEWAY_REDIS_PORT=6379
DATACLOUD_GATEWAY_REDIS_DB=0
# 无密码可留空或删除该行
DATACLOUD_GATEWAY_REDIS_PASSWORD=
DATACLOUD_GATEWAY_REDIS_USERNAME=
DATACLOUD_GATEWAY_CONSUMER_GROUP=datacloud
DATACLOUD_GATEWAY_WORKSPACE_DIR=/tmp/datacloud

# -------------------------------------------------------------
# 十、AI Factory 数字员工（init_agent_conf 插件）
# -------------------------------------------------------------
DATACLOUD_AI_FACTORY_URL=http://127.0.0.1:8080
# Beyond-Token，与 findDetailsById 请求头一致
# DATACLOUD_AI_FACTORY_TOKEN=
# 待加载的 resourceId 列表，JSON 数组（不再调用 getResourceListByPage）
# DATACLOUD_AI_FACTORY_AGENT_IDS=["10000587","10000582"]
