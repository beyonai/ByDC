        <request_method rdf:datatype="http://www.w3.org/2001/XMLSchema#string">POST</request_method>
        <request_header rdf:resource="#http_header"/>
        <request_params rdf:resource="#param_query_industry_profile_chainName"/>
        <request_params rdf:resource="#param_query_industry_profile_chainId"/>
