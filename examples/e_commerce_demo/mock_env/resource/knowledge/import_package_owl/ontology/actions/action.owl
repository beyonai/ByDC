    <owl:Class rdf:about="#ResponseParameter"><rdfs:label>响应参数</rdfs:label></owl:Class>
    <owl:Class rdf:about="#HeaderParameter"><rdfs:label>请求头参数</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#action_query_enterprise_profile">
        <rdf:type rdf:resource="#ActionDefinition"/>
        <action_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">query_enterprise_profile</action_code>
        <action_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">按企业名称或企业ID查询企业画像</action_name>
        <action_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">按企业名称、企业ID和年份查询企业年度画像。</action_desc>
        <action_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">QUERY(UPDATE:操作, QUERY:查询)</action_type>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <function_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;query_enterprise_profile&quot;]</function_refs>
        <belong_entity rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;dws_enterprise_wide&quot;]</belong_entity>
        <request_url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">/query_enterprise_profile</request_url>
        <request_method rdf:datatype="http://www.w3.org/2001/XMLSchema#string">POST</request_method>
        <request_header rdf:resource="#http_header"/>
        <request_params rdf:resource="#param_query_enterprise_profile_enterpriseName"/>
        <request_params rdf:resource="#param_query_enterprise_profile_enterpriseId"/>
        <request_params rdf:resource="#param_query_enterprise_profile_dataYear"/>
        <response_params rdf:resource="#resp_query_enterprise_profile_enterpriseId"/>
        <response_params rdf:resource="#resp_query_enterprise_profile_enterpriseName"/>
        <response_params rdf:resource="#resp_query_enterprise_profile_gridName"/>
        <response_params rdf:resource="#resp_query_enterprise_profile_chainName"/>
        <response_params rdf:resource="#resp_query_enterprise_profile_annualRevenueReport"/>
        <response_params rdf:resource="#resp_query_enterprise_profile_taxDeclared"/>
        <response_params rdf:resource="#resp_query_enterprise_profile_riskLevel"/>
        <response_params rdf:resource="#resp_query_enterprise_profile_latestPatternName"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#action_query_grid_profile">
        <rdf:type rdf:resource="#ActionDefinition"/>
        <action_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">query_grid_profile</action_code>
        <action_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">按网格查询网格经营情况</action_name>
        <action_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">按网格名称、网格ID和年份查询网格年度治理画像。</action_desc>
        <action_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">QUERY(UPDATE:操作, QUERY:查询)</action_type>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <function_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;query_grid_profile&quot;]</function_refs>
        <belong_entity rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;dws_grid_wide&quot;]</belong_entity>
        <request_url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">/query_grid_profile</request_url>
        <request_method rdf:datatype="http://www.w3.org/2001/XMLSchema#string">POST</request_method>
        <request_header rdf:resource="#http_header"/>
        <request_params rdf:resource="#param_query_grid_profile_gridName"/>
        <request_params rdf:resource="#param_query_grid_profile_gridId"/>
        <request_params rdf:resource="#param_query_grid_profile_dataYear"/>
        <response_params rdf:resource="#resp_query_grid_profile_gridId"/>
        <response_params rdf:resource="#resp_query_grid_profile_gridName"/>
        <response_params rdf:resource="#resp_query_grid_profile_enterpriseCnt"/>
        <response_params rdf:resource="#resp_query_grid_profile_totalAnnualRevenue"/>
        <response_params rdf:resource="#resp_query_grid_profile_avgRiskScore"/>
        <response_params rdf:resource="#resp_query_grid_profile_vitalityIdx"/>
        <response_params rdf:resource="#resp_query_grid_profile_weaknessTag"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#action_query_industry_profile">
        <rdf:type rdf:resource="#ActionDefinition"/>
        <action_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">query_industry_profile</action_code>
        <action_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">按产业链查询产业链画像</action_name>
