    <owl:NamedIndividual rdf:about="#dws_industry_wide_v1">
        <rdf:type rdf:resource="#EntityDefinition"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dws_industry_wide</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业链数据对象</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业链粒度年度分析对象，覆盖产业链规模、龙头结构、开票能力、关系强度和链内风险等指标。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <entity_source rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DB</entity_source>
        <fields rdf:resource="#chainId_field"/>
        <fields rdf:resource="#dataYear_field"/>
        <fields rdf:resource="#chainName_field"/>
        <fields rdf:resource="#parentChainId_field"/>
        <fields rdf:resource="#parentChainName_field"/>
        <fields rdf:resource="#chainLevel_field"/>
        <fields rdf:resource="#chainDescription_field"/>
        <fields rdf:resource="#nodeCnt_field"/>
        <fields rdf:resource="#keyNodeCnt_field"/>
        <fields rdf:resource="#enterpriseCnt_field"/>
        <fields rdf:resource="#scaleEnterpriseCnt_field"/>
        <fields rdf:resource="#highTechCnt_field"/>
        <fields rdf:resource="#leadingEnterpriseCnt_field"/>
        <fields rdf:resource="#gridCnt_field"/>
        <fields rdf:resource="#regionCnt_field"/>
        <fields rdf:resource="#totalAnnualRevenue_field"/>
        <fields rdf:resource="#totalTaxDeclared_field"/>
        <fields rdf:resource="#avgRiskScore_field"/>
        <fields rdf:resource="#highRiskCnt_field"/>
        <fields rdf:resource="#invoiceIssuedAmtYear_field"/>
        <fields rdf:resource="#invoiceReceivedAmtYear_field"/>
        <fields rdf:resource="#intraChainRelCnt_field"/>
        <fields rdf:resource="#supplierRelOutCnt_field"/>
        <fields rdf:resource="#buyerRelOutCnt_field"/>
        <fields rdf:resource="#relationStrengthSum_field"/>
        <fields rdf:resource="#latestJudgmentTime_field"/>
        <fields rdf:resource="#etlTime_field"/>
        <action_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;query_industry_profile&quot;]</action_refs>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;rel_industry_parent_industry&quot;]</relations>
    </owl:NamedIndividual>

