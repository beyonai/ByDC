        <fields rdf:resource="#busAdress_field"/>
        <fields rdf:resource="#regAddress_field"/>
        <fields rdf:resource="#poiLatitude_field"/>
        <fields rdf:resource="#poiLongitude_field"/>
        <fields rdf:resource="#poiAdress_field"/>
        <fields rdf:resource="#annualRevenueReport_field"/>
        <fields rdf:resource="#taxDeclared_field"/>
        <fields rdf:resource="#landAreaMu_field"/>
        <fields rdf:resource="#powerConsumption_field"/>
        <fields rdf:resource="#waterConsumption_field"/>
        <fields rdf:resource="#logisticsHeatIndex_field"/>
        <fields rdf:resource="#revenueAiInferred_field"/>
        <fields rdf:resource="#taxAiInferred_field"/>
        <fields rdf:resource="#taxGapRatio_field"/>
        <fields rdf:resource="#riskScore_field"/>
        <fields rdf:resource="#riskLevel_field"/>
        <fields rdf:resource="#isScaleEnterprise_field"/>
        <fields rdf:resource="#isHighTech_field"/>
        <fields rdf:resource="#highLevelTalents_field"/>
        <fields rdf:resource="#patentsNum_field"/>
        <fields rdf:resource="#rdIntensity_field"/>
        <fields rdf:resource="#isListed_field"/>
        <fields rdf:resource="#enterpriseLevel_field"/>
        <fields rdf:resource="#dataSource_field"/>
        <fields rdf:resource="#locationReality_field"/>
        <fields rdf:resource="#chooseWho_field"/>
        <fields rdf:resource="#isRisk_field"/>
        <fields rdf:resource="#invoiceIssuedAmount_field"/>
