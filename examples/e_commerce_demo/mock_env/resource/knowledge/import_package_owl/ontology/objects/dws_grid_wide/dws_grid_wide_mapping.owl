<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#dws_grid_wide_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dws_grid_wide</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">网格年度治理画像</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">网格粒度年度治理对象，覆盖企业汇总、资产利用、IoT 活力和空间治理类指标。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#gridId_mapping"/>
        <mapping rdf:resource="#dataYear_mapping"/>
        <mapping rdf:resource="#gridCode_mapping"/>
        <mapping rdf:resource="#gridName_mapping"/>
        <mapping rdf:resource="#regionId_mapping"/>
        <mapping rdf:resource="#regionName_mapping"/>
        <mapping rdf:resource="#polygon_mapping"/>
        <mapping rdf:resource="#areaMu_mapping"/>
        <mapping rdf:resource="#areaKilometer_mapping"/>
        <mapping rdf:resource="#centerPoint_mapping"/>
        <mapping rdf:resource="#enterpriseCnt_mapping"/>
        <mapping rdf:resource="#scaleEnterpriseCnt_mapping"/>
        <mapping rdf:resource="#highTechCnt_mapping"/>
        <mapping rdf:resource="#totalAnnualRevenue_mapping"/>
        <mapping rdf:resource="#totalTaxDeclared_mapping"/>
        <mapping rdf:resource="#avgRiskScore_mapping"/>
        <mapping rdf:resource="#highRiskCnt_mapping"/>
        <mapping rdf:resource="#assetCnt_mapping"/>
        <mapping rdf:resource="#occupiedAssetCnt_mapping"/>
        <mapping rdf:resource="#vacantAssetCnt_mapping"/>
        <mapping rdf:resource="#totalLandAreaMu_mapping"/>
        <mapping rdf:resource="#totalFloorAreaSqm_mapping"/>
        <mapping rdf:resource="#kpiMonthTime_mapping"/>
        <mapping rdf:resource="#outputPerMu_mapping"/>
        <mapping rdf:resource="#vitalityIdx_mapping"/>
        <mapping rdf:resource="#weaknessTag_mapping"/>
        <mapping rdf:resource="#iotLatestDate_mapping"/>
        <mapping rdf:resource="#humanFlowIdx_mapping"/>
        <mapping rdf:resource="#trafficFlowIdxDay_mapping"/>
        <mapping rdf:resource="#nightLightIdxDay_mapping"/>
        <mapping rdf:resource="#logisticsHeatIdxDay_mapping"/>
        <mapping rdf:resource="#iotMonthTime_mapping"/>
        <mapping rdf:resource="#peopleFlowIdxMonth_mapping"/>
        <mapping rdf:resource="#trafficFlowIdxMonth_mapping"/>
        <mapping rdf:resource="#logisticsIdxMonth_mapping"/>
        <mapping rdf:resource="#nightLightIdxMonth_mapping"/>
        <mapping rdf:resource="#riskWeightMonth_mapping"/>
        <mapping rdf:resource="#etlTime_mapping"/>
    </owl:NamedIndividual>

