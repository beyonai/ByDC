        <mapping rdf:resource="#busAdress_mapping"/>
        <mapping rdf:resource="#regAddress_mapping"/>
        <mapping rdf:resource="#poiLatitude_mapping"/>
        <mapping rdf:resource="#poiLongitude_mapping"/>
        <mapping rdf:resource="#poiAdress_mapping"/>
        <mapping rdf:resource="#annualRevenueReport_mapping"/>
        <mapping rdf:resource="#taxDeclared_mapping"/>
        <mapping rdf:resource="#landAreaMu_mapping"/>
        <mapping rdf:resource="#powerConsumption_mapping"/>
        <mapping rdf:resource="#waterConsumption_mapping"/>
        <mapping rdf:resource="#logisticsHeatIndex_mapping"/>
        <mapping rdf:resource="#revenueAiInferred_mapping"/>
        <mapping rdf:resource="#taxAiInferred_mapping"/>
        <mapping rdf:resource="#taxGapRatio_mapping"/>
        <mapping rdf:resource="#riskScore_mapping"/>
        <mapping rdf:resource="#riskLevel_mapping"/>
        <mapping rdf:resource="#isScaleEnterprise_mapping"/>
        <mapping rdf:resource="#isHighTech_mapping"/>
        <mapping rdf:resource="#highLevelTalents_mapping"/>
        <mapping rdf:resource="#patentsNum_mapping"/>
        <mapping rdf:resource="#rdIntensity_mapping"/>
        <mapping rdf:resource="#isListed_mapping"/>
        <mapping rdf:resource="#enterpriseLevel_mapping"/>
        <mapping rdf:resource="#dataSource_mapping"/>
        <mapping rdf:resource="#locationReality_mapping"/>
        <mapping rdf:resource="#chooseWho_mapping"/>
        <mapping rdf:resource="#isRisk_mapping"/>
        <mapping rdf:resource="#invoiceIssuedAmount_mapping"/>
        <mapping rdf:resource="#invoiceReceivedAmount_mapping"/>
