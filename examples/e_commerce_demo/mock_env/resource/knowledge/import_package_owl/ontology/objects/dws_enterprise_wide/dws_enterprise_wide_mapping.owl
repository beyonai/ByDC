    <owl:NamedIndividual rdf:about="#dws_enterprise_wide_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dws_enterprise_wide</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业年度画像</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业粒度年度画像对象，覆盖企业身份归属、经营申报、风险研判、资产占用和产业链关系等核心指标。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#enterpriseId_mapping"/>
        <mapping rdf:resource="#dataYear_mapping"/>
        <mapping rdf:resource="#enterpriseName_mapping"/>
        <mapping rdf:resource="#industryCode_mapping"/>
        <mapping rdf:resource="#industryName_mapping"/>
        <mapping rdf:resource="#gridId_mapping"/>
        <mapping rdf:resource="#gridName_mapping"/>
