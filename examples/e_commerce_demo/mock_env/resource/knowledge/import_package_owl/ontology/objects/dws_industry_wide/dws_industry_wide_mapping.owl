        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业维度大宽表字段映射定义</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[{"property_code": "chainId", "property_name": "产业链ID", "source_table_code": "dws_industry_wide", "source_column_code": "chain_id", "source_datasource_code": "resource_csv"}, {"property_code": "dataYear", "property_name": "数据年份", "source_table_code": "dws_industry_wide", "source_column_code": "data_year", "source_datasource_code": "resource_csv"}, {"property_code": "chainName", "property_name": "产业链名称", "source_table_code": "dws_industry_wide", "source_column_code": "chain_name", "source_datasource_code": "resource_csv"}, {"property_code": "parentChainId", "property_name": "父产业链ID", "source_table_code": "dws_industry_wide", "source_column_code": "parent_chain_id", "source_datasource_code": "resource_csv"}, {"property_code": "parentChainName", "property_name": "父产业链名称", "source_table_code": "dws_industry_wide", "source_column_code": "parent_chain_name", "source_datasource_code": "resource_csv"}, {"property_code": "chainLevel", "property_name": "产业链层级", "source_table_code": "dws_industry_wide", "source_column_code": "chain_level", "source_datasource_code": "resource_csv"}, {"property_code": "chainDescription", "property_name": "产业链描述", "source_table_code": "dws_industry_wide", "source_column_code": "chain_description", "source_datasource_code": "resource_csv"}, {"property_code": "nodeCnt", "property_name": "环节节点数", "source_table_code": "dws_industry_wide", "source_column_code": "node_cnt", "source_datasource_code": "resource_csv"}, {"property_code": "keyNodeCnt", "property_name": "关键环节节点数", "source_table_code": "dws_industry_wide", "source_column_code": "key_node_cnt", "source_datasource_code": "resource_csv"}, {"property_code": "enterpriseCnt", "property_name": "企业数", "source_table_code": "dws_industry_wide", "source_column_code": "enterprise_cnt", "source_datasource_code": "resource_csv"}, {"property_code": "scaleEnterpriseCnt", "property_name": "规上企业数", "source_table_code": "dws_industry_wide", "source_column_code": "scale_enterprise_cnt", "source_datasource_code": "resource_csv"}, {"property_code": "highTechCnt", "property_name": "高新企业数", "source_table_code": "dws_industry_wide", "source_column_code": "high_tech_cnt", "source_datasource_code": "resource_csv"}, {"property_code": "leadingEnterpriseCnt", "property_name": "龙头企业数", "source_table_code": "dws_industry_wide", "source_column_code": "leading_enterprise_cnt", "source_datasource_code": "resource_csv"}, {"property_code": "gridCnt", "property_name": "覆盖网格数", "source_table_code": "dws_industry_wide", "source_column_code": "grid_cnt", "source_datasource_code": "resource_csv"}, {"property_code": "regionCnt", "property_name": "覆盖区域数", "source_table_code": "dws_industry_wide", "source_column_code": "region_cnt", "source_datasource_code": "resource_csv"}, {"property_code": "totalAnnualRevenue", "property_name": "申报营收汇总", "source_table_code": "dws_industry_wide", "source_column_code": "total_annual_revenue", "source_datasource_code": "resource_csv"}, {"property_code": "totalTaxDeclared", "property_name": "申报税额汇总", "source_table_code": "dws_industry_wide", "source_column_code": "total_tax_declared", "source_datasource_code": "resource_csv"}, {"property_code": "avgRiskScore", "property_name": "平均风险分", "source_table_code": "dws_industry_wide", "source_column_code": "avg_risk_score", "source_datasource_code": "resource_csv"}, {"property_code": "highRiskCnt", "property_name": "高风险企业数", "source_table_code": "dws_industry_wide", "source_column_code": "high_risk_cnt", "source_datasource_code": "resource_csv"}, {"property_code": "invoiceIssuedAmtYear", "property_name": "当年开票额", "source_table_code": "dws_industry_wide", "source_column_code": "invoice_issued_amt_year", "source_datasource_code": "resource_csv"}, {"property_code": "invoiceReceivedAmtYear", "property_name": "当年收票额", "source_table_code": "dws_industry_wide", "source_column_code": "invoice_received_amt_year", "source_datasource_code": "resource_csv"}, {"property_code": "intraChainRelCnt", "property_name": "链内供需关系数", "source_table_code": "dws_industry_wide", "source_column_code": "intra_chain_rel_cnt", "source_datasource_code": "resource_csv"}, {"property_code": "supplierRelOutCnt", "property_name": "对外供应关系数", "source_table_code": "dws_industry_wide", "source_column_code": "supplier_rel_out_cnt", "source_datasource_code": "resource_csv"}, {"property_code": "buyerRelOutCnt", "property_name": "对外采购关系数", "source_table_code": "dws_industry_wide", "source_column_code": "buyer_rel_out_cnt", "source_datasource_code": "resource_csv"}, {"property_code": "relationStrengthSum", "property_name": "关系强度汇总", "source_table_code": "dws_industry_wide", "source_column_code": "relation_strength_sum", "source_datasource_code": "resource_csv"}, {"property_code": "latestJudgmentTime", "property_name": "链内企业最新研判时间(最大)", "source_table_code": "dws_industry_wide", "source_column_code": "latest_judgment_time", "source_datasource_code": "resource_csv"}, {"property_code": "etlTime", "property_name": "装载时间", "source_table_code": "dws_industry_wide", "source_column_code": "etl_time", "source_datasource_code": "resource_csv"}]</mapping>
    </owl:NamedIndividual>
