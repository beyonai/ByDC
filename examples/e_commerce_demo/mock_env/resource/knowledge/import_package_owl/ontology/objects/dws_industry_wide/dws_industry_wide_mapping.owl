<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#dws_industry_wide_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dws_industry_wide</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业链年度画像</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业链粒度年度分析对象，覆盖产业链规模、龙头结构、开票能力、关系强度和链内风险等指标。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#chainId_mapping"/>
        <mapping rdf:resource="#dataYear_mapping"/>
        <mapping rdf:resource="#chainName_mapping"/>
        <mapping rdf:resource="#parentChainId_mapping"/>
        <mapping rdf:resource="#parentChainName_mapping"/>
        <mapping rdf:resource="#chainLevel_mapping"/>
        <mapping rdf:resource="#chainDescription_mapping"/>
        <mapping rdf:resource="#nodeCnt_mapping"/>
        <mapping rdf:resource="#keyNodeCnt_mapping"/>
        <mapping rdf:resource="#enterpriseCnt_mapping"/>
        <mapping rdf:resource="#scaleEnterpriseCnt_mapping"/>
        <mapping rdf:resource="#highTechCnt_mapping"/>
        <mapping rdf:resource="#leadingEnterpriseCnt_mapping"/>
        <mapping rdf:resource="#gridCnt_mapping"/>
        <mapping rdf:resource="#regionCnt_mapping"/>
        <mapping rdf:resource="#totalAnnualRevenue_mapping"/>
        <mapping rdf:resource="#totalTaxDeclared_mapping"/>
        <mapping rdf:resource="#avgRiskScore_mapping"/>
        <mapping rdf:resource="#highRiskCnt_mapping"/>
        <mapping rdf:resource="#invoiceIssuedAmtYear_mapping"/>
        <mapping rdf:resource="#invoiceReceivedAmtYear_mapping"/>
        <mapping rdf:resource="#intraChainRelCnt_mapping"/>
        <mapping rdf:resource="#supplierRelOutCnt_mapping"/>
        <mapping rdf:resource="#buyerRelOutCnt_mapping"/>
        <mapping rdf:resource="#relationStrengthSum_mapping"/>
        <mapping rdf:resource="#latestJudgmentTime_mapping"/>
        <mapping rdf:resource="#etlTime_mapping"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#chainId_mapping">
