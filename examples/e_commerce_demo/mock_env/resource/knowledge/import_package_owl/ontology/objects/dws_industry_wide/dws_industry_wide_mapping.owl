        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业链ID</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dws_industry_wide</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">chain_id</source_column_code>
        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">e_commerce_demo_db</source_datasource_code>
    </owl:NamedIndividual>
