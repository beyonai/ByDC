<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#ads_enterprise_analysis_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业综合分析表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业综合分析宽表，整合企业经营、税收、利润、网格活力、产业环节、企业等级、风险等级等信息，主键为 `enterprise_id`。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#enterprise_id_mapping"/>
        <mapping rdf:resource="#enterprise_name_mapping"/>
        <mapping rdf:resource="#stat_date_mapping"/>
        <mapping rdf:resource="#industry_name_mapping"/>
        <mapping rdf:resource="#business_status_name_mapping"/>
        <mapping rdf:resource="#lng_lat_mapping"/>
        <mapping rdf:resource="#height_mapping"/>
        <mapping rdf:resource="#address_mapping"/>
        <mapping rdf:resource="#total_revenue_mapping"/>
        <mapping rdf:resource="#total_tax_mapping"/>
        <mapping rdf:resource="#total_profit_mapping"/>
        <mapping rdf:resource="#tax_rate_mapping"/>
        <mapping rdf:resource="#avg_foot_traffic_mapping"/>
        <mapping rdf:resource="#foot_active_level_name_mapping"/>
        <mapping rdf:resource="#avg_vehicle_flow_mapping"/>
        <mapping rdf:resource="#vehicle_active_level_name_mapping"/>
        <mapping rdf:resource="#avg_light_intensity_mapping"/>
        <mapping rdf:resource="#light_active_level_name_mapping"/>
        <mapping rdf:resource="#chain_code_mapping"/>
        <mapping rdf:resource="#chain_name_mapping"/>
        <mapping rdf:resource="#manage_grid_id_mapping"/>
        <mapping rdf:resource="#manage_grid_name_mapping"/>
        <mapping rdf:resource="#enterprise_level_name_mapping"/>
        <mapping rdf:resource="#risk_level_name_mapping"/>
        <mapping rdf:resource="#update_time_mapping"/>
        <mapping rdf:resource="#etl_create_time_mapping"/>
        <mapping rdf:resource="#phy_grid_id_mapping"/>
        <mapping rdf:resource="#phy_grid_name_mapping"/>
        <mapping rdf:resource="#energy_efficiency_index_mapping"/>
    </owl:NamedIndividual>
