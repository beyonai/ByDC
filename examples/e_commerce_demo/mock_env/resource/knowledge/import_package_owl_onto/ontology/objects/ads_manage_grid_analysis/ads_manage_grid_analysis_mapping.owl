<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#ads_manage_grid_analysis_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_manage_grid_analysis</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">管理网格综合分析表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">管理网格综合分析宽表，聚合管理网格面积、经营指标、IoT 活跃度、灯光、POI 密度等信息，主键为 `manage_grid_id`。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#manage_grid_id_mapping"/>
        <mapping rdf:resource="#manage_grid_name_mapping"/>
        <mapping rdf:resource="#grid_lnt_lat_mapping"/>
        <mapping rdf:resource="#manage_wkt_mapping"/>
        <mapping rdf:resource="#stat_date_mapping"/>
        <mapping rdf:resource="#area_sqm_mapping"/>
        <mapping rdf:resource="#total_revenue_mapping"/>
        <mapping rdf:resource="#total_tax_mapping"/>
        <mapping rdf:resource="#total_profit_mapping"/>
        <mapping rdf:resource="#tax_rate_mapping"/>
        <mapping rdf:resource="#output_per_mu_mapping"/>
        <mapping rdf:resource="#avg_foot_traffic_mapping"/>
        <mapping rdf:resource="#foot_active_level_name_mapping"/>
        <mapping rdf:resource="#avg_vehicle_flow_mapping"/>
        <mapping rdf:resource="#vehicle_active_level_name_mapping"/>
        <mapping rdf:resource="#avg_light_intensity_mapping"/>
        <mapping rdf:resource="#light_active_level_name_mapping"/>
        <mapping rdf:resource="#poi_density_mapping"/>
        <mapping rdf:resource="#update_time_mapping"/>
        <mapping rdf:resource="#etl_create_time_mapping"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#manage_grid_id_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">manage_grid_id</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">管理网格编码</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_manage_grid_analysis</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">manage_grid_id</source_column_code>
        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">yizhuang_brain</source_datasource_code>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#manage_grid_name_mapping">
