    <owl:Class rdf:about="#TermDefinition"><rdfs:label>术语定义</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#term_object_ads_enterprise_analysis">
        <rdf:type rdf:resource="#TermDefinition"/>
        <term_code_path rdf:datatype="http://www.w3.org/2001/XMLSchema#string">OBJECT#ads_enterprise_analysis</term_code_path>
        <term_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</term_code>
        <term_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业综合分析表</term_name>
        <library_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LIB_002</library_code>
        <term_type_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">object</term_type_code>
        <term_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业综合分析宽表，整合企业经营、税收、利润、网格活力、产业环节、企业等级、风险等级等信息，主键为 enterprise_id。</term_desc>
        <synonyms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</synonyms>
        <terms_knowledge rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</terms_knowledge>
        <domain_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DOMAIN_002</domain_code>
        <owl_doc_file rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ontology/objects/ads_enterprise_analysis/ads_enterprise_analysis_object.owl</owl_doc_file>
        <ext_field rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></ext_field>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#term_object_ads_grid_analysis">
        <rdf:type rdf:resource="#TermDefinition"/>
        <term_code_path rdf:datatype="http://www.w3.org/2001/XMLSchema#string">OBJECT#ads_grid_analysis</term_code_path>
