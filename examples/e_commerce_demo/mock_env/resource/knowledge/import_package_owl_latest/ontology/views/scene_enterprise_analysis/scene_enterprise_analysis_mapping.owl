<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#scene_enterprise_analysis_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">scene_enterprise_analysis</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业综合分析视图</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">以企业为 anchor，整合经营、税收、风险、网格活力、产业链等指标的联合分析视图。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#enterprise_id_mapping"/>
        <mapping rdf:resource="#enterprise_name_mapping"/>
        <mapping rdf:resource="#stat_date_mapping"/>
        <mapping rdf:resource="#industry_name_mapping"/>
        <mapping rdf:resource="#business_status_name_mapping"/>
        <mapping rdf:resource="#total_revenue_mapping"/>
        <mapping rdf:resource="#total_tax_mapping"/>
        <mapping rdf:resource="#total_profit_mapping"/>
        <mapping rdf:resource="#tax_rate_mapping"/>
        <mapping rdf:resource="#enterprise_level_name_mapping"/>
        <mapping rdf:resource="#risk_level_name_mapping"/>
        <mapping rdf:resource="#manage_grid_name_mapping"/>
        <mapping rdf:resource="#phy_grid_name_mapping"/>
        <mapping rdf:resource="#chain_name_mapping"/>
        <mapping rdf:resource="#energy_efficiency_Index_mapping"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#enterprise_id_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">enterprise_id</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业唯一 ID</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">enterprise_id</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;primary_key&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#enterprise_name_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">enterprise_name</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业全称</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">enterprise_name</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;name&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#stat_date_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">stat_date</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">统计日期</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">stat_date</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;period&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#industry_name_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">industry_name</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">行业类型</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">industry_name</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;name&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#business_status_name_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">business_status_name</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业经营状态</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">business_status_name</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;name&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#total_revenue_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total_revenue</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业总营收（万元）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total_revenue</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;basic_metric&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#total_tax_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total_tax</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业总缴税（万元）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total_tax</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;basic_metric&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#total_profit_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total_profit</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业总利润（万元）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total_profit</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;basic_metric&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#tax_rate_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tax_rate</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业实际税负率（%）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tax_rate</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;derived_metric&quot;}, &quot;formula&quot;: &quot;CASE WHEN total_revenue &gt; 0 THEN total_tax / total_revenue * 100 ELSE NULL END&quot;}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#enterprise_level_name_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">enterprise_level_name</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业等级</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">enterprise_level_name</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;name&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#risk_level_name_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">risk_level_name</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业综合风险等级</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">risk_level_name</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;name&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#manage_grid_name_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">manage_grid_name</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">所属管理网格名称</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">manage_grid_name</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;name&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#phy_grid_name_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">phy_grid_name</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业所属物理网格名称</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">phy_grid_name</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;name&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#chain_name_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">chain_name</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">所属产业环节名称</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">chain_name</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;name&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#energy_efficiency_Index_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">energy_efficiency_Index</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业经济效益等级</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">energy_efficiency_Index</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;name&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:DatatypeProperty rdf:about="#entity_code"/>
    <owl:DatatypeProperty rdf:about="#entity_name"/>
    <owl:DatatypeProperty rdf:about="#entity_desc"/>
    <owl:DatatypeProperty rdf:about="#version"/>
    <owl:ObjectProperty rdf:about="#mapping"/>
    <owl:DatatypeProperty rdf:about="#property_code"/>
    <owl:DatatypeProperty rdf:about="#property_name"/>
    <owl:DatatypeProperty rdf:about="#source_object_code"/>
    <owl:DatatypeProperty rdf:about="#source_object_column_code"/>
    <owl:DatatypeProperty rdf:about="#ext_property"/>
</rdf:RDF>
