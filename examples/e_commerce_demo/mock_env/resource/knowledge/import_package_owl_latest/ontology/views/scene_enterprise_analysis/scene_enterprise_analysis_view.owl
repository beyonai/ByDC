<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/scene/ontology#">

    <owl:Class rdf:about="#SceneDefinition"><rdfs:label>视图定义</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#scene_enterprise_analysis_v1">
        <rdf:type rdf:resource="#SceneDefinition"/>
        <view_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">scene_enterprise_analysis</view_code>
        <view_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业综合分析视图</view_name>
        <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">以企业为 anchor，整合经营、税收、风险、网格活力、产业链等指标的联合分析视图。</description>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <object_codes rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;ads_enterprise_analysis&quot;, &quot;ads_grid_analysis&quot;, &quot;ads_manage_grid_analysis&quot;, &quot;ads_chain_analysis&quot;]</object_codes>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;rel_scene_enterprise_analysis_to_ads_enterprise_analysis&quot;, &quot;rel_scene_enterprise_analysis_to_ads_grid_analysis&quot;, &quot;rel_scene_enterprise_analysis_to_ads_manage_grid_analysis&quot;, &quot;rel_scene_enterprise_analysis_to_ads_chain_analysis&quot;, &quot;rel_ads_enterprise_analysis_to_ads_manage_grid_analysis&quot;, &quot;rel_ads_enterprise_analysis_to_ads_grid_analysis&quot;, &quot;rel_ads_grid_analysis_to_ads_manage_grid_analysis&quot;, &quot;rel_ads_enterprise_analysis_to_ads_chain_analysis&quot;]</relations>
    </owl:NamedIndividual>

    <owl:DatatypeProperty rdf:about="#view_code"/>
    <owl:DatatypeProperty rdf:about="#view_name"/>
    <owl:DatatypeProperty rdf:about="#description"/>
    <owl:DatatypeProperty rdf:about="#version"/>
    <owl:DatatypeProperty rdf:about="#object_codes"/>
    <owl:DatatypeProperty rdf:about="#relations"/>
</rdf:RDF>
