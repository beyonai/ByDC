<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#scene_grid_analysis_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">scene_grid_analysis</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格综合分析视图</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">以物理网格为 anchor，聚合网格经营指标、IoT 活力、亩产效益，关联所属管理网格。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#phy_grid_id_mapping"/>
        <mapping rdf:resource="#phy_grid_name_mapping"/>
        <mapping rdf:resource="#stat_date_mapping"/>
        <mapping rdf:resource="#manage_grid_name_mapping"/>
        <mapping rdf:resource="#total_revenue_mapping"/>
        <mapping rdf:resource="#total_tax_mapping"/>
        <mapping rdf:resource="#total_profit_mapping"/>
        <mapping rdf:resource="#tax_rate_mapping"/>
        <mapping rdf:resource="#output_per_mu_mapping"/>
        <mapping rdf:resource="#area_sqm_mapping"/>
        <mapping rdf:resource="#avg_foot_traffic_mapping"/>
        <mapping rdf:resource="#avg_vehicle_flow_mapping"/>
        <mapping rdf:resource="#avg_light_intensity_mapping"/>
        <mapping rdf:resource="#poi_density_mapping"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#phy_grid_id_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">phy_grid_id</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格编码</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">phy_grid_id</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;primary_key&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#phy_grid_name_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">phy_grid_name</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格名称</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">phy_grid_name</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;name&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#stat_date_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">stat_date</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">统计日期</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">stat_date</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;period&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#manage_grid_name_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">manage_grid_name</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">管理网格名称</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">manage_grid_name</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;DIMENSION&quot;, &quot;rule_type&quot;: &quot;name&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#total_revenue_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total_revenue</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格总营收（万元）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total_revenue</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;basic_metric&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#total_tax_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total_tax</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格总缴税（万元）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total_tax</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;basic_metric&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#total_profit_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total_profit</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格总利润（万元）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">total_profit</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;basic_metric&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#tax_rate_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tax_rate</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格实际税负率（%）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tax_rate</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;derived_metric&quot;}, &quot;formula&quot;: &quot;CASE WHEN total_revenue &gt; 0 THEN total_tax / total_revenue * 100 ELSE NULL END&quot;}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#output_per_mu_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">output_per_mu</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格亩产效益（万元/亩）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">output_per_mu</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;formula_metric&quot;}, &quot;formula&quot;: &quot;CASE WHEN area_sqm &gt; 0 THEN total_revenue / (area_sqm / 10000) ELSE NULL END&quot;}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#area_sqm_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">area_sqm</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格面积（平方米）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">area_sqm</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;raw_number&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#avg_foot_traffic_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">avg_foot_traffic</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格日均人流量（人次）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">avg_foot_traffic</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;basic_metric&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#avg_vehicle_flow_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">avg_vehicle_flow</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格日均车流量（辆次）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">avg_vehicle_flow</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;basic_metric&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#avg_light_intensity_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">avg_light_intensity</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格夜间灯光强度</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">avg_light_intensity</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;basic_metric&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#poi_density_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">poi_density</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">物理网格POI密度（个/平方公里）</property_name>
        <source_object_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_grid_analysis</source_object_code>
        <source_object_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">poi_density</source_object_column_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{&quot;property_role_rule&quot;: {&quot;property_role&quot;: &quot;MEASURE&quot;, &quot;rule_type&quot;: &quot;basic_metric&quot;}}</ext_property>
    </owl:NamedIndividual>

    <owl:DatatypeProperty rdf:about="#entity_code"/>
    <owl:DatatypeProperty rdf:about="#entity_name"/>
    <owl:DatatypeProperty rdf:about="#entity_desc"/>
    <owl:DatatypeProperty rdf:about="#version"/>
    <owl:ObjectProperty rdf:about="#mapping"/>
    <owl:DatatypeProperty rdf:about="#property_code"/>
    <owl:DatatypeProperty rdf:about="#property_name"/>
    <owl:DatatypeProperty rdf:about="#source_object_code"/>
    <owl:DatatypeProperty rdf:about="#source_object_column_code"/>
    <owl:DatatypeProperty rdf:about="#ext_property"/>
</rdf:RDF>
