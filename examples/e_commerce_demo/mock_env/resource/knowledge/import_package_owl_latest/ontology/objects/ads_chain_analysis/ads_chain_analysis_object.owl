    <owl:NamedIndividual rdf:about="#ads_chain_analysis_v1">
        <rdf:type rdf:resource="#EntityDefinition"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_chain_analysis</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业链分析表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业链分析表，记录产业环节信息、环节企业数量、营收、税收、利润等指标，用于分析产业链效益。主键为 city_name+chain_item_code。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <entity_source rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DB</entity_source>
        <fields rdf:resource="#city_name_field"/>
        <fields rdf:resource="#chain_type_code_field"/>
        <fields rdf:resource="#chain_type_name_field"/>
        <fields rdf:resource="#chain_code_field"/>
        <fields rdf:resource="#chain_name_field"/>
        <fields rdf:resource="#chain_item_code_field"/>
        <fields rdf:resource="#item_type_field"/>
        <fields rdf:resource="#chain_item_name_field"/>
        <fields rdf:resource="#ENTERPRISE_NUM_field"/>
        <fields rdf:resource="#total_revenue_field"/>
        <fields rdf:resource="#total_tax_field"/>
        <fields rdf:resource="#total_profit_field"/>
        <fields rdf:resource="#item_strengths_field"/>
        <fields rdf:resource="#item_weaknesses_field"/>
        <fields rdf:resource="#update_time_field"/>
        <fields rdf:resource="#etl_create_time_field"/>
        <fields rdf:resource="#industrial_chain_efficiency_field"/>
        <action_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;query_ads_chain_analysis&quot;]</action_refs>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</relations>
    </owl:NamedIndividual>

