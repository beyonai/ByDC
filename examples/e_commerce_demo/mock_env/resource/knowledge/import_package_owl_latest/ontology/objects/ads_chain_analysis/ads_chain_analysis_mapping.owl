<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#ads_chain_analysis_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_chain_analysis</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业链分析表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业链分析表，记录产业环节信息、环节企业数量、营收、税收、利润等指标，用于分析产业链效益。主键为 city_name+chain_item_code。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#city_name_mapping"/>
        <mapping rdf:resource="#chain_type_code_mapping"/>
        <mapping rdf:resource="#chain_type_name_mapping"/>
        <mapping rdf:resource="#chain_code_mapping"/>
        <mapping rdf:resource="#chain_name_mapping"/>
        <mapping rdf:resource="#chain_item_code_mapping"/>
        <mapping rdf:resource="#item_type_mapping"/>
        <mapping rdf:resource="#chain_item_name_mapping"/>
        <mapping rdf:resource="#ENTERPRISE_NUM_mapping"/>
        <mapping rdf:resource="#total_revenue_mapping"/>
        <mapping rdf:resource="#total_tax_mapping"/>
        <mapping rdf:resource="#total_profit_mapping"/>
        <mapping rdf:resource="#item_strengths_mapping"/>
        <mapping rdf:resource="#item_weaknesses_mapping"/>
        <mapping rdf:resource="#update_time_mapping"/>
        <mapping rdf:resource="#etl_create_time_mapping"/>
        <mapping rdf:resource="#industrial_chain_efficiency_mapping"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#city_name_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">city_name</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">城市名称</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_chain_analysis</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">city_name</source_column_code>
        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">yizhuang_brain</source_datasource_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{"property_role_rule": {"property_role": "MEASURE", "rule_type": "primary_key"}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#chain_type_code_mapping">
