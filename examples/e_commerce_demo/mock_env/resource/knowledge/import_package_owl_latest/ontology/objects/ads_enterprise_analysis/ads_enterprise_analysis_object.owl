<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/ontology#">

    <owl:Class rdf:about="#EntityDefinition"><rdfs:label>实体定义</rdfs:label></owl:Class>
    <owl:Class rdf:about="#EntityField"><rdfs:label>实体字段</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#ads_enterprise_analysis_v1">
        <rdf:type rdf:resource="#EntityDefinition"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_enterprise_analysis</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业综合分析表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业税收风险判别，整合企业经营、风险明细指标，计算综合风险评估分、风险标签，直接支撑税务风险核查、分级管控，主键：enterprise_id，外键关联所有企业相关枚举维度表。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <entity_source rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DB</entity_source>
        <fields rdf:resource="#enterprise_id_field"/>
        <fields rdf:resource="#enterprise_name_field"/>
        <fields rdf:resource="#stat_date_field"/>
        <fields rdf:resource="#industry_name_field"/>
        <fields rdf:resource="#business_status_name_field"/>
        <fields rdf:resource="#lng_lat_field"/>
        <fields rdf:resource="#address_field"/>
        <fields rdf:resource="#total_revenue_field"/>
        <fields rdf:resource="#total_tax_field"/>
        <fields rdf:resource="#total_profit_field"/>
        <fields rdf:resource="#tax_rate_field"/>
        <fields rdf:resource="#avg_foot_traffic_field"/>
        <fields rdf:resource="#foot_active_level_name_field"/>
        <fields rdf:resource="#avg_vehicle_flow_field"/>
        <fields rdf:resource="#vehicle_active_level_name_field"/>
        <fields rdf:resource="#avg_logistics_activity_field"/>
        <fields rdf:resource="#logistics_active_level_name_field"/>
        <fields rdf:resource="#avg_light_intensity_field"/>
        <fields rdf:resource="#light_active_level_name_field"/>
        <fields rdf:resource="#chain_code_field"/>
        <fields rdf:resource="#chain_name_field"/>
        <fields rdf:resource="#manager_grid_id_field"/>
        <fields rdf:resource="#manager_grid_name_field"/>
        <fields rdf:resource="#enterprise_level_name_field"/>
        <fields rdf:resource="#risk_level_name_field"/>
        <fields rdf:resource="#update_time_field"/>
        <fields rdf:resource="#etl_create_time_field"/>
        <fields rdf:resource="#grid_id_field"/>
        <fields rdf:resource="#grid_name_field"/>
        <fields rdf:resource="#energy_efficiency_index_field"/>
        <action_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">["query_ads_enterprise_analysis"]</action_refs>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">["rel_ads_enterprise_analysis_to_ads_manage_grid_analysis", "rel_ads_enterprise_analysis_to_ads_grid_analysis"]</relations>
    </owl:NamedIndividual>
