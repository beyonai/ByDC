    <owl:NamedIndividual rdf:about="#ads_manage_grid_analysis_v1">
        <rdf:type rdf:resource="#EntityDefinition"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_manage_grid_analysis</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">管理网格综合分析表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">管理网格综合分析宽表，聚合管理网格面积、经营指标、IoT 活跃度、灯光、POI 密度等信息，主键为 `manage_grid_id`。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <entity_source rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DB</entity_source>
        <fields rdf:resource="#manage_grid_id_field"/>
        <fields rdf:resource="#manage_grid_name_field"/>
        <fields rdf:resource="#grid_lnt_lat_field"/>
        <fields rdf:resource="#manage_wkt_field"/>
        <fields rdf:resource="#stat_date_field"/>
        <fields rdf:resource="#area_sqm_field"/>
        <fields rdf:resource="#total_revenue_field"/>
        <fields rdf:resource="#total_tax_field"/>
        <fields rdf:resource="#total_profit_field"/>
        <fields rdf:resource="#tax_rate_field"/>
        <fields rdf:resource="#output_per_mu_field"/>
        <fields rdf:resource="#avg_foot_traffic_field"/>
        <fields rdf:resource="#foot_active_level_name_field"/>
        <fields rdf:resource="#avg_vehicle_flow_field"/>
        <fields rdf:resource="#vehicle_active_level_name_field"/>
        <fields rdf:resource="#avg_light_intensity_field"/>
        <fields rdf:resource="#light_active_level_name_field"/>
        <fields rdf:resource="#poi_density_field"/>
        <fields rdf:resource="#update_time_field"/>
        <fields rdf:resource="#etl_create_time_field"/>
        <fields rdf:resource="#energy_efficiency_index_field"/>
        <action_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">["query_ads_manage_grid_analysis"]</action_refs>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</relations>
    </owl:NamedIndividual>
