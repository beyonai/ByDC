    <owl:NamedIndividual rdf:about="#tax_rate_field">
        <rdf:type rdf:resource="#EntityField"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tax_rate</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">管理网格实际税负率（%）</property_name>
        <data_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">STRING</data_type>
        <is_required rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</is_required>
        <default_value rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></default_value>
        <source_column rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tax_rate</source_column>
        <synonyms rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></synonyms>
        <data_format rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></data_format>
        <measurement_unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></measurement_unit>
        <property_category rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></property_category>
        <property_group rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COMPUTED</property_group>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{"property_role_rule": {"property_role": "MEASURE", "rule_type": "derived_metric"}, "formula": "CASE WHEN total_revenue > 0 THEN total_tax / total_revenue * 100 ELSE NULL END"}</ext_property>
        <term_type_code_path rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></term_type_code_path>
        <library_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></library_code>
        <rel_action rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</rel_action>
        <rel_term_codeorname rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></rel_term_codeorname>
        <term_data_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></term_data_type>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#output_per_mu_field">
        <rdf:type rdf:resource="#EntityField"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">output_per_mu</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">管理网格亩产效益（万元/亩）</property_name>
        <data_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DOUBLE</data_type>
        <is_required rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</is_required>
