         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/term/ontology#">

    <owl:Class rdf:about="#TermDefinition">
        <rdfs:label>术语定义</rdfs:label>
    </owl:Class>

    <owl:NamedIndividual rdf:about="#term_object_ads_enterprise_analysis">
        <rdf:type rdf:resource="#TermDefinition"/>
        <term_code_path rdf:datatype="http://www.w3.org/2001/XMLSchema#string">OBJECT#ADS_ENTERPRISE_ANALYSIS</term_code_path>
        <term_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ADS_ENTERPRISE_ANALYSIS</term_code>
        <term_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业综合分析表</term_name>
        <library_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LIB_002</library_code>
        <term_type_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">OBJECT</term_type_code>
        <term_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业税收风险判别，整合企业经营、风险明细指标，计算综合风险评估分、风险标签，直接支撑税务风险核查、分级管控，主键：enterprise_id，外键关联所有企业相关枚举维度表。</term_desc>
        <synonyms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</synonyms>
        <terms_knowledge rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</terms_knowledge>
        <domain_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DOMAIN_002</domain_code>
        <owl_doc_file rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ontology/objects/ads_enterprise_analysis/ads_enterprise_analysis_object.owl</owl_doc_file>
        <ext_field rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></ext_field>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#term_action_ads_enterprise_analysis">
        <rdf:type rdf:resource="#TermDefinition"/>
        <term_code_path rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ACTION#query_ads_enterprise_analysis</term_code_path>
        <term_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">query_ads_enterprise_analysis</term_code>
        <term_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">查询企业综合分析表</term_name>
        <library_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LIB_002</library_code>
        <term_type_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ACTION</term_type_code>
        <term_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">查询企业综合分析表动作</term_desc>
        <synonyms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</synonyms>
        <terms_knowledge rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</terms_knowledge>
        <domain_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DOMAIN_002</domain_code>
        <owl_doc_file rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ontology/actions/action.owl</owl_doc_file>
        <ext_field rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></ext_field>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#term_object_ads_investment_analysis">
        <rdf:type rdf:resource="#TermDefinition"/>
        <term_code_path rdf:datatype="http://www.w3.org/2001/XMLSchema#string">OBJECT#ADS_INVESTMENT_ANALYSIS</term_code_path>
        <term_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ADS_INVESTMENT_ANALYSIS</term_code>
        <term_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">招商分析核心表</term_name>
        <library_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LIB_002</library_code>
        <term_type_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">OBJECT</term_type_code>
        <term_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业大脑招商，整合企业、网格、资产指标，筛选优质招商企业、潜力招商区域、空置招商载体，直接支撑招商决策，主键：investment_id</term_desc>
        <synonyms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</synonyms>
        <terms_knowledge rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</terms_knowledge>
        <domain_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DOMAIN_002</domain_code>
        <owl_doc_file rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ontology/objects/ads_investment_analysis/ads_investment_analysis_object.owl</owl_doc_file>
        <ext_field rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></ext_field>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#term_action_ads_investment_analysis">
        <rdf:type rdf:resource="#TermDefinition"/>
        <term_code_path rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ACTION#query_ads_investment_analysis</term_code_path>
