<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/ontology#">

    <owl:Class rdf:about="#EntityDefinition"><rdfs:label>实体定义</rdfs:label></owl:Class>
    <owl:Class rdf:about="#EntityField"><rdfs:label>实体字段</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#ads_investment_analysis_v1">
        <rdf:type rdf:resource="#EntityDefinition"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ADS_INVESTMENT_ANALYSIS</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">招商分析核心表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业大脑招商，整合企业、网格、资产指标，筛选优质招商企业、潜力招商区域、空置招商载体，直接支撑招商决策，主键：investment_id</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <entity_source rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DB</entity_source>
        <fields rdf:resource="#investmentId_field"/>
        <fields rdf:resource="#adminCode_field"/>
        <fields rdf:resource="#adminName_field"/>
        <fields rdf:resource="#industryCode_field"/>
        <fields rdf:resource="#industryName_field"/>
        <fields rdf:resource="#gridId_field"/>
        <fields rdf:resource="#gridComprehensiveActive_field"/>
        <fields rdf:resource="#gridActiveLevelName_field"/>
        <fields rdf:resource="#buildingId_field"/>
        <fields rdf:resource="#buildingName_field"/>
        <fields rdf:resource="#buildingEmptyRate_field"/>
        <fields rdf:resource="#buildingEmptyArea_field"/>
        <fields rdf:resource="#assetValuation_field"/>
        <fields rdf:resource="#targetEnterpriseCount_field"/>
        <fields rdf:resource="#leaderEnterpriseCount_field"/>
        <fields rdf:resource="#topEnterpriseList_field"/>
        <fields rdf:resource="#industryChainComplete_field"/>
        <fields rdf:resource="#industryChainGap_field"/>
        <fields rdf:resource="#investmentPotentialScore_field"/>
        <fields rdf:resource="#investmentPotentialLevel_field"/>
        <fields rdf:resource="#recommendInvest_field"/>
        <fields rdf:resource="#gridFootTraffic_field"/>
        <fields rdf:resource="#gridVehicleFlow_field"/>
        <fields rdf:resource="#updateTime_field"/>
        <fields rdf:resource="#etlCreateTime_field"/>
        <action_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;query_ads_investment_analysis&quot;]</action_refs>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;rel_investment_grid&quot;, &quot;rel_enterprise_investment&quot;]</relations>
    </owl:NamedIndividual>

