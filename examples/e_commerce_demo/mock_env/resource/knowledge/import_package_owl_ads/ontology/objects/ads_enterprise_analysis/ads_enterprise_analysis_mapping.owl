<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#ads_enterprise_analysis_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ADS_ENTERPRISE_ANALYSIS</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业综合分析表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业税收风险判别，整合企业经营、风险明细指标，计算综合风险评估分、风险标签，直接支撑税务风险核查、分级管控，主键：enterprise_id，外键关联所有企业相关枚举维度表。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#enterpriseId_mapping"/>
        <mapping rdf:resource="#enterpriseName_mapping"/>
        <mapping rdf:resource="#statDate_mapping"/>
        <mapping rdf:resource="#industryName_mapping"/>
        <mapping rdf:resource="#businessStatusName_mapping"/>
        <mapping rdf:resource="#lngLat_mapping"/>
        <mapping rdf:resource="#address_mapping"/>
        <mapping rdf:resource="#totalRevenue_mapping"/>
        <mapping rdf:resource="#totalTax_mapping"/>
        <mapping rdf:resource="#totalProfit_mapping"/>
        <mapping rdf:resource="#taxRate_mapping"/>
        <mapping rdf:resource="#avgFootTraffic_mapping"/>
        <mapping rdf:resource="#footActiveLevelName_mapping"/>
        <mapping rdf:resource="#avgVehicleFlow_mapping"/>
        <mapping rdf:resource="#vehicleActiveLevelName_mapping"/>
        <mapping rdf:resource="#avgLogisticsActivity_mapping"/>
        <mapping rdf:resource="#logisticsActiveLevelName_mapping"/>
        <mapping rdf:resource="#avgLightIntensity_mapping"/>
        <mapping rdf:resource="#lightActiveLevelName_mapping"/>
        <mapping rdf:resource="#chainCode_mapping"/>
        <mapping rdf:resource="#chainName_mapping"/>
        <mapping rdf:resource="#gridId_mapping"/>
        <mapping rdf:resource="#gridName_mapping"/>
        <mapping rdf:resource="#enterpriseLevelName_mapping"/>
        <mapping rdf:resource="#riskLevelName_mapping"/>
        <mapping rdf:resource="#updateTime_mapping"/>
        <mapping rdf:resource="#etlCreateTime_mapping"/>
        <mapping rdf:resource="#areaCode_mapping"/>
        <mapping rdf:resource="#areaName_mapping"/>
        <mapping rdf:resource="#energyEfficiencyIndex_mapping"/>
    </owl:NamedIndividual>

