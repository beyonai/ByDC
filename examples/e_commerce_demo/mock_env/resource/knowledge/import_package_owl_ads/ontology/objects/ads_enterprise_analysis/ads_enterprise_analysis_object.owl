        <library_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></library_code>
        <rel_action rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</rel_action>
        <rel_term_codeorname rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></rel_term_codeorname>
        <term_data_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></term_data_type>
    </owl:NamedIndividual>
