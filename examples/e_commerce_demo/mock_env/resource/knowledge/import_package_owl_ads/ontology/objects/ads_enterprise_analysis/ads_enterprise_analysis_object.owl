<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/ontology#">

    <owl:Class rdf:about="#EntityDefinition"><rdfs:label>实体定义</rdfs:label></owl:Class>
    <owl:Class rdf:about="#EntityField"><rdfs:label>实体字段</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#ads_enterprise_analysis_v1">
        <rdf:type rdf:resource="#EntityDefinition"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ADS_ENTERPRISE_ANALYSIS</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业综合分析表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">企业税收风险判别，整合企业经营、风险明细指标，计算综合风险评估分、风险标签，直接支撑税务风险核查、分级管控，主键：enterprise_id，外键关联所有企业相关枚举维度表。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <entity_source rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DB</entity_source>
        <fields rdf:resource="#enterpriseId_field"/>
        <fields rdf:resource="#enterpriseName_field"/>
        <fields rdf:resource="#statDate_field"/>
        <fields rdf:resource="#industryName_field"/>
        <fields rdf:resource="#businessStatusName_field"/>
        <fields rdf:resource="#lngLat_field"/>
        <fields rdf:resource="#address_field"/>
        <fields rdf:resource="#totalRevenue_field"/>
        <fields rdf:resource="#totalTax_field"/>
        <fields rdf:resource="#totalProfit_field"/>
        <fields rdf:resource="#taxRate_field"/>
        <fields rdf:resource="#avgFootTraffic_field"/>
        <fields rdf:resource="#footActiveLevelName_field"/>
        <fields rdf:resource="#avgVehicleFlow_field"/>
        <fields rdf:resource="#vehicleActiveLevelName_field"/>
        <fields rdf:resource="#avgLogisticsActivity_field"/>
        <fields rdf:resource="#logisticsActiveLevelName_field"/>
        <fields rdf:resource="#avgLightIntensity_field"/>
        <fields rdf:resource="#lightActiveLevelName_field"/>
        <fields rdf:resource="#chainCode_field"/>
        <fields rdf:resource="#chainName_field"/>
        <fields rdf:resource="#gridId_field"/>
        <fields rdf:resource="#gridName_field"/>
        <fields rdf:resource="#enterpriseLevelName_field"/>
        <fields rdf:resource="#riskLevelName_field"/>
        <fields rdf:resource="#updateTime_field"/>
        <fields rdf:resource="#etlCreateTime_field"/>
        <fields rdf:resource="#areaCode_field"/>
        <fields rdf:resource="#areaName_field"/>
        <fields rdf:resource="#energyEfficiencyIndex_field"/>
        <action_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;query_ads_enterprise_analysis&quot;]</action_refs>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;rel_enterprise_grid&quot;, &quot;rel_enterprise_investment&quot;]</relations>
    </owl:NamedIndividual>

