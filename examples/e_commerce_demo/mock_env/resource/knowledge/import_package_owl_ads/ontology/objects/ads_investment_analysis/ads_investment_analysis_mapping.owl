<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#ads_investment_analysis_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ads_investment_analysis</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">招商分析核心表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产业大脑招商，整合企业、网格、资产指标，筛选优质招商企业、潜力招商区域、空置招商载体，直接支撑招商决策，主键：investment_id</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#investmentId_mapping"/>
        <mapping rdf:resource="#adminCode_mapping"/>
        <mapping rdf:resource="#adminName_mapping"/>
        <mapping rdf:resource="#industryCode_mapping"/>
        <mapping rdf:resource="#industryName_mapping"/>
        <mapping rdf:resource="#gridId_mapping"/>
        <mapping rdf:resource="#gridComprehensiveActive_mapping"/>
        <mapping rdf:resource="#gridActiveLevelName_mapping"/>
        <mapping rdf:resource="#buildingId_mapping"/>
        <mapping rdf:resource="#buildingName_mapping"/>
        <mapping rdf:resource="#buildingEmptyRate_mapping"/>
        <mapping rdf:resource="#buildingEmptyArea_mapping"/>
        <mapping rdf:resource="#assetValuation_mapping"/>
        <mapping rdf:resource="#targetEnterpriseCount_mapping"/>
        <mapping rdf:resource="#leaderEnterpriseCount_mapping"/>
        <mapping rdf:resource="#topEnterpriseList_mapping"/>
        <mapping rdf:resource="#industryChainComplete_mapping"/>
        <mapping rdf:resource="#industryChainGap_mapping"/>
        <mapping rdf:resource="#investmentPotentialScore_mapping"/>
        <mapping rdf:resource="#investmentPotentialLevel_mapping"/>
        <mapping rdf:resource="#recommendInvest_mapping"/>
        <mapping rdf:resource="#gridFootTraffic_mapping"/>
        <mapping rdf:resource="#gridVehicleFlow_mapping"/>
        <mapping rdf:resource="#updateTime_mapping"/>
        <mapping rdf:resource="#etlCreateTime_mapping"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#investmentId_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">investmentId</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">招商分析唯一  ID</property_name>
