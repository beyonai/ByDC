        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">investment_id</source_column_code>
        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">model_v2_ads_db</source_datasource_code>
    </owl:NamedIndividual>
