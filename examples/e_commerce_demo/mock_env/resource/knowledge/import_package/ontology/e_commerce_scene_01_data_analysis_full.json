      "actions": [
        {
          "action_code": "query_reports_by_scope",
          "action_name": "按网格区域与分类查询报告",
          "description": "根据分类及网格/区域名称列表读取 Markdown；两列表为空时返回该分类下全部报告；reports 根目录：环境变量优先，否则相对 cwd / 向上查找 mock_env/resource/reports",
          "action_type": "query",
          "function_refs": [],
          "script": "import os\n\ndef _root_from_cwd():\n    cwd = os.path.abspath(os.getcwd())\n    rels = (\n        (\"resource\", \"reports\"),\n        (\"mock_env\", \"resource\", \"reports\"),\n        (\"examples\", \"e_commerce_demo\", \"mock_env\", \"resource\", \"reports\"),\n    )\n    seen = set()\n    for parts in rels:\n        p = os.path.normpath(os.path.join(cwd, *parts))\n        if p not in seen:\n            seen.add(p)\n            if os.path.isdir(p):\n                return p\n    cur = cwd\n    for _ in range(10):\n        p = os.path.join(cur, \"mock_env\", \"resource\", \"reports\")\n        if p not in seen:\n            seen.add(p)\n            if os.path.isdir(p):\n                return p\n        parent = os.path.dirname(cur)\n        if parent == cur:\n            break\n        cur = parent\n    return \"\"\n\ndef _root():\n    env = os.environ.get(\"DATACLOUD_E_COMMERCE_REPORTS_ROOT\", \"\").strip()\n    if env and os.path.isdir(env):\n        return env\n    return _root_from_cwd()\n\ndef _title_from_md(text):\n    for line in text.splitlines():\n        s = line.strip()\n        if s.startswith(\"#\"):\n            return s.lstrip(\"#\").strip() or None\n    return None\n\ndef _load_one(base, category, filename):\n    path = os.path.join(base, category, filename)\n    if not os.path.isfile(path):\n        return None\n    with open(path, encoding=\"utf-8\") as f:\n        body = f.read()\n    stem = filename[:-3] if filename.endswith(\".md\") else filename\n    name = _title_from_md(body) or stem\n    addr = \"reports/%s/%s\" % (category, filename)\n    return {\"reportName\": name, \"reportContent\": body, \"reportAddress\": addr}\n\ndef execute(params):\n    params = params or {}\n    category = (params.get(\"category\") or \"\").strip()\n    grids = params.get(\"gridNames\") or []\n    regions = params.get(\"regionNames\") or []\n    base = _root()\n    if not base or not category:\n        return {\"reports\": []}\n    cat_dir = os.path.join(base, category)\n    if not os.path.isdir(cat_dir):\n        return {\"reports\": []}\n\n    seen = set()\n    out = []\n\n    def add_file(fn):\n        if fn in seen:\n            return\n        rec = _load_one(base, category, fn)\n        if rec:\n            seen.add(fn)\n            out.append(rec)\n\n    for g in grids:\n        if g:\n            add_file(\"网格_%s.md\" % str(g).strip())\n    for r in regions:\n        if r:\n            add_file(\"区_%s.md\" % str(r).strip())\n\n    if not grids and not regions:\n        for fn in sorted(os.listdir(cat_dir)):\n            if fn.endswith(\".md\"):\n                add_file(fn)\n\n    return {\"reports\": out}\n",
          "params": [
            {
              "param_code": "gridNames",
              "param_name": "网格名称列表",
