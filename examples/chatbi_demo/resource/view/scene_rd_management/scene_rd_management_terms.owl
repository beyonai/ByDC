    <owl:NamedIndividual rdf:about="#term_view_scene_rd_management">
        <rdf:type rdf:resource="#TermDefinition"/>
        <term_code_path rdf:datatype="http://www.w3.org/2001/XMLSchema#string">VIEW#scene_rd_management</term_code_path>
        <term_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">scene_rd_management</term_code>
        <term_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">研发管理视图</term_name>
