        <view_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">研发管理视图</view_name>
        <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">以研发任务为 anchor，LEFT JOIN 项目、客户、用户、组织，分析需求、开发、测试、故障处理和研发延期。</description>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <object_codes rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;by_rd_task&quot;, &quot;by_project&quot;, &quot;by_customer&quot;, &quot;po_users&quot;, &quot;po_organization&quot;]</object_codes>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;rel_scene_rd_management_to_by_rd_task&quot;, &quot;rel_scene_rd_management_to_by_project&quot;, &quot;rel_scene_rd_management_to_by_customer&quot;, &quot;rel_scene_rd_management_to_po_users&quot;, &quot;rel_scene_rd_management_to_po_organization&quot;, &quot;rel_by_rd_task_to_po_users_initiator&quot;, &quot;rel_by_rd_task_to_po_users_handler&quot;]</relations>
