    <owl:NamedIndividual rdf:about="#term_view_scene_project_management">
        <rdf:type rdf:resource="#TermDefinition"/>
        <term_code_path rdf:datatype="http://www.w3.org/2001/XMLSchema#string">VIEW#scene_project_management</term_code_path>
        <term_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">scene_project_management</term_code>
        <term_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">项目管理视图</term_name>
        <library_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LIB_WUKONG_CRM</library_code>
        <term_type_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">view</term_type_code>
        <term_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">以项目为 anchor，LEFT JOIN 客户、商机、项目任务、用户、组织，分析项目履约、上线、收入、回款和欠费。</term_desc>
        <synonyms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</synonyms>
        <terms_knowledge rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</terms_knowledge>
        <domain_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DOMAIN_WUKONG_CRM</domain_code>
        <owl_doc_file rdf:datatype="http://www.w3.org/2001/XMLSchema#string">view/scene_project_management/scene_project_management_definition.owl</owl_doc_file>
        <ext_field rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></ext_field>
        <parent_term_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></parent_term_code>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
    </owl:NamedIndividual>

