    <owl:NamedIndividual rdf:about="#scene_project_management_v1">
        <rdf:type rdf:resource="#SceneDefinition"/>
        <view_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">scene_project_management</view_code>
        <view_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">项目管理视图</view_name>
        <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">以项目为 anchor，LEFT JOIN 客户、商机、项目任务、用户、组织，分析项目履约、上线、收入、回款和欠费。</description>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <object_codes rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;by_project&quot;, &quot;by_customer&quot;, &quot;by_opportunity&quot;, &quot;by_project_task&quot;, &quot;po_users&quot;, &quot;po_organization&quot;]</object_codes>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;rel_scene_project_management_to_by_project&quot;, &quot;rel_scene_project_management_to_by_customer&quot;, &quot;rel_scene_project_management_to_by_opportunity&quot;, &quot;rel_scene_project_management_to_by_project_task&quot;, &quot;rel_scene_project_management_to_po_users&quot;, &quot;rel_scene_project_management_to_po_organization&quot;, &quot;rel_by_project_to_by_opportunity&quot;, &quot;rel_by_project_to_by_project_task&quot;, &quot;rel_by_project_to_po_users_sales&quot;, &quot;rel_by_project_to_po_organization&quot;]</relations>
