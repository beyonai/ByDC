    <owl:Class rdf:about="#TermRelation"><rdfs:label>术语关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#rel_by_project_to_by_opportunity">
        <rdf:type rdf:resource="#TermRelation"/>
        <source_libeary rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LIB_WUKONG_CRM</source_libeary>
        <source_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">object</source_type>
        <source_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_project</source_code>
        <target_libeary rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LIB_WUKONG_CRM</target_libeary>
        <target_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">object</target_type>
        <target_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_opportunity</target_code>
        <relation_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">项目关联商机</relation_name>
        <relation_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MANY_TO_ONE</relation_type>
        <joinkeys rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[{"sourceField":"opp_id","targetField":"id","joinType":"LEFT"}]</joinkeys>
        <ext_field rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></ext_field>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
    </owl:NamedIndividual>
