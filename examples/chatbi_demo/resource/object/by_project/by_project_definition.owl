<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/ontology#">

    <owl:Class rdf:about="#EntityDefinition"><rdfs:label>实体定义</rdfs:label></owl:Class>
    <owl:Class rdf:about="#EntityField"><rdfs:label>实体字段</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#by_project_v1">
        <rdf:type rdf:resource="#EntityDefinition"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_project</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">项目信息表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">项目履约对象，承载客户、关联商机、项目状态、合同、收入、回款、欠费和计划/实际月份。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <entity_source rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DB</entity_source>
        <fields rdf:resource="#id_field"/>
        <fields rdf:resource="#project_code_field"/>
        <fields rdf:resource="#project_name_field"/>
        <fields rdf:resource="#industry_field"/>
        <fields rdf:resource="#domain_field"/>
        <fields rdf:resource="#customer_code_field"/>
        <fields rdf:resource="#sales_user_id_field"/>
        <fields rdf:resource="#dept_id_field"/>
        <fields rdf:resource="#opp_id_field"/>
        <fields rdf:resource="#product_code_field"/>
        <fields rdf:resource="#project_status_field"/>
        <fields rdf:resource="#contract_amount_field"/>
        <fields rdf:resource="#revenue_amount_field"/>
        <fields rdf:resource="#payment_amount_field"/>
        <fields rdf:resource="#arrear_amount_field"/>
        <fields rdf:resource="#plan_online_date_field"/>
        <fields rdf:resource="#actual_online_date_field"/>
        <fields rdf:resource="#plan_revenue_date_field"/>
        <fields rdf:resource="#actual_revenue_date_field"/>
        <fields rdf:resource="#plan_payment_date_field"/>
        <fields rdf:resource="#actual_payment_date_field"/>
        <fields rdf:resource="#create_by_field"/>
        <fields rdf:resource="#create_time_field"/>
        <fields rdf:resource="#update_by_field"/>
        <fields rdf:resource="#update_time_field"/>
        <fields rdf:resource="#remark_field"/>
        <action_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">["create_by_project","update_by_project","delete_by_project"]</action_refs>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;rel_by_project_to_by_opportunity&quot;, &quot;rel_by_project_to_by_project_task&quot;, &quot;rel_by_project_to_by_rd_task&quot;, &quot;rel_by_project_to_po_users_sales&quot;, &quot;rel_by_project_to_po_organization&quot;]</relations>
    </owl:NamedIndividual>

