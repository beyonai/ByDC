        <action_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">分页查询客户信息，支持按编码、名称、状态等字段过滤，返回 TableDataInfo 分页结果。</action_desc>
        <action_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">QUERY</action_type>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
