        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">wukong_crm_demo</source_datasource_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{"property_role_rule": {"property_role": "DIMENSION", "rule_type": "id"}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#customer_name_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">customer_name</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">客户名称</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_customer</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">customer_name</source_column_code>
        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">wukong_crm_demo</source_datasource_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{"property_role_rule": {"property_role": "DIMENSION", "rule_type": "name"}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#industry_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">industry</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">所属行业</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_customer</source_table_code>
