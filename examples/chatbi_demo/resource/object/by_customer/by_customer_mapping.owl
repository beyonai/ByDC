    <owl:NamedIndividual rdf:about="#province_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">province</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">所属省份(dict_type: province)</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_customer</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">province</source_column_code>
        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">wukong_crm_demo</source_datasource_code>
