<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/ontology#">

    <owl:Class rdf:about="#EntityDefinition"><rdfs:label>实体定义</rdfs:label></owl:Class>
    <owl:Class rdf:about="#EntityField"><rdfs:label>实体字段</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#by_opportunity_v1">
        <rdf:type rdf:resource="#EntityDefinition"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_opportunity</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">商机信息表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">销售商机对象，承载客户、产品、阶段状态、预测金额、签约金额和签约月份。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <entity_source rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DB</entity_source>
        <fields rdf:resource="#id_field"/>
        <fields rdf:resource="#opp_code_field"/>
        <fields rdf:resource="#opp_name_field"/>
        <fields rdf:resource="#industry_field"/>
        <fields rdf:resource="#domain_field"/>
        <fields rdf:resource="#customer_code_field"/>
        <fields rdf:resource="#sales_user_id_field"/>
        <fields rdf:resource="#dept_id_field"/>
        <fields rdf:resource="#product_code_field"/>
        <fields rdf:resource="#opp_status_field"/>
        <fields rdf:resource="#forecast_amount_field"/>
        <fields rdf:resource="#contract_amount_field"/>
        <fields rdf:resource="#forecast_rate_field"/>
        <fields rdf:resource="#fail_reason_field"/>
        <fields rdf:resource="#success_summary_field"/>
        <fields rdf:resource="#plan_sign_date_field"/>
        <fields rdf:resource="#actual_sign_date_field"/>
        <fields rdf:resource="#create_by_field"/>
        <fields rdf:resource="#create_time_field"/>
        <fields rdf:resource="#update_by_field"/>
        <fields rdf:resource="#update_time_field"/>
        <fields rdf:resource="#remark_field"/>
        <action_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">["create_by_opportunity","update_by_opportunity","get_by_opportunity","list_by_opportunity","delete_by_opportunity"]</action_refs>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;rel_by_opportunity_to_by_project&quot;, &quot;rel_by_opportunity_to_by_opp_task&quot;, &quot;rel_by_opportunity_to_po_users_sales&quot;, &quot;rel_by_opportunity_to_po_organization&quot;]</relations>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#id_field">
