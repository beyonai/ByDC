    <owl:Class rdf:about="#TermDefinition"><rdfs:label>术语定义</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#term_object_by_opportunity">
        <rdf:type rdf:resource="#TermDefinition"/>
        <term_code_path rdf:datatype="http://www.w3.org/2001/XMLSchema#string">OBJECT#by_opportunity</term_code_path>
        <term_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_opportunity</term_code>
        <term_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">商机信息表</term_name>
        <library_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LIB_WUKONG_CRM</library_code>
        <term_type_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">object</term_type_code>
        <term_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">销售商机对象，承载客户、产品、阶段状态、预测金额、签约金额和签约月份。</term_desc>
        <synonyms rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</synonyms>
        <terms_knowledge rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</terms_knowledge>
        <domain_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DOMAIN_WUKONG_CRM</domain_code>
        <owl_doc_file rdf:datatype="http://www.w3.org/2001/XMLSchema#string">object/by_opportunity/by_opportunity_definition.owl</owl_doc_file>
        <ext_field rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></ext_field>
        <parent_term_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></parent_term_code>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
    </owl:NamedIndividual>

