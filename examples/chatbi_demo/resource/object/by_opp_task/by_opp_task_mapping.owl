        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">任务类型(1线索获取 2方案交流 3商务报价 4商务应标 5商机签约 6应标复盘)</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_opp_task</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">task_type</source_column_code>
