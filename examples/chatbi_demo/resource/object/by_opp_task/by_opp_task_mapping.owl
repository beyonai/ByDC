    <owl:NamedIndividual rdf:about="#product_code_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">product_code</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">产品编码(dict_type: product)</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_opp_task</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">product_code</source_column_code>
