<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#by_opp_task_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_opp_task</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">商机任务表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">商机推进任务对象，记录商机跟进、商务应标、签约复盘等销售过程任务。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#id_mapping"/>
        <mapping rdf:resource="#customer_code_mapping"/>
        <mapping rdf:resource="#opp_code_mapping"/>
        <mapping rdf:resource="#product_code_mapping"/>
        <mapping rdf:resource="#opp_task_type_mapping"/>
        <mapping rdf:resource="#initiator_user_id_mapping"/>
        <mapping rdf:resource="#handler_user_id_mapping"/>
        <mapping rdf:resource="#opp_task_status_mapping"/>
        <mapping rdf:resource="#task_name_mapping"/>
        <mapping rdf:resource="#task_desc_mapping"/>
        <mapping rdf:resource="#handle_desc_mapping"/>
        <mapping rdf:resource="#initiate_time_mapping"/>
        <mapping rdf:resource="#plan_finish_time_mapping"/>
        <mapping rdf:resource="#actual_finish_time_mapping"/>
        <mapping rdf:resource="#create_by_mapping"/>
        <mapping rdf:resource="#create_time_mapping"/>
        <mapping rdf:resource="#update_by_mapping"/>
        <mapping rdf:resource="#update_time_mapping"/>
        <mapping rdf:resource="#remark_mapping"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#id_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">id</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">主键</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_opp_task</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">id</source_column_code>
        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">wukong_crm_demo</source_datasource_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{"property_role_rule": {"property_role": "MEASURE", "rule_type": "primary_key"}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#customer_code_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">customer_code</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">客户编码(ref: by_customer.customer_code)</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_opp_task</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">customer_code</source_column_code>
        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">wukong_crm_demo</source_datasource_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{"property_role_rule": {"property_role": "DIMENSION", "rule_type": "id"}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#opp_code_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">opp_code</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">商机编码(ref: by_opportunity.opp_code)</property_name>
