<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#po_users_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">po_users</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">用户信息表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">平台用户维度对象，承载销售、发起人、处理人等人员信息。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#user_id_mapping"/>
        <mapping rdf:resource="#user_name_mapping"/>
        <mapping rdf:resource="#email_mapping"/>
        <mapping rdf:resource="#phone_mapping"/>
        <mapping rdf:resource="#user_code_mapping"/>
        <mapping rdf:resource="#pwd_mapping"/>
        <mapping rdf:resource="#address_mapping"/>
        <mapping rdf:resource="#remark_mapping"/>
        <mapping rdf:resource="#user_eff_date_mapping"/>
        <mapping rdf:resource="#user_exp_date_mapping"/>
        <mapping rdf:resource="#create_date_mapping"/>
        <mapping rdf:resource="#update_date_mapping"/>
        <mapping rdf:resource="#state_mapping"/>
        <mapping rdf:resource="#state_time_mapping"/>
        <mapping rdf:resource="#is_locked_mapping"/>
        <mapping rdf:resource="#last_login_date_mapping"/>
        <mapping rdf:resource="#security_question_id_mapping"/>
        <mapping rdf:resource="#security_answer_mapping"/>
        <mapping rdf:resource="#thumbnail_uri_mapping"/>
        <mapping rdf:resource="#ext_attr_mapping"/>
        <mapping rdf:resource="#assistant_id_mapping"/>
        <mapping rdf:resource="#user_number_mapping"/>
        <mapping rdf:resource="#station_id_mapping"/>
        <mapping rdf:resource="#register_type_mapping"/>
        <mapping rdf:resource="#apple_user_id_mapping"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#user_id_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">user_id</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">用户唯一标识</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">po_users</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">user_id</source_column_code>
        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">byai_platform</source_datasource_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{"property_role_rule": {"property_role": "DIMENSION", "rule_type": "id"}}</ext_property>
    </owl:NamedIndividual>

