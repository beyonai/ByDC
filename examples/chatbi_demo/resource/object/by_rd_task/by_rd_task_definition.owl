    <owl:Class rdf:about="#EntityDefinition"><rdfs:label>实体定义</rdfs:label></owl:Class>
    <owl:Class rdf:about="#EntityField"><rdfs:label>实体字段</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#by_rd_task_v1">
        <rdf:type rdf:resource="#EntityDefinition"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_rd_task</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">研发任务表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">研发任务对象，记录需求分析、产品设计、功能开发、测试、故障分析和故障处理任务。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <entity_source rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DB</entity_source>
        <fields rdf:resource="#id_field"/>
        <fields rdf:resource="#project_code_field"/>
        <fields rdf:resource="#opp_code_field"/>
        <fields rdf:resource="#customer_code_field"/>
        <fields rdf:resource="#product_code_field"/>
        <fields rdf:resource="#rd_task_type_field"/>
        <fields rdf:resource="#initiator_user_id_field"/>
        <fields rdf:resource="#handler_user_id_field"/>
        <fields rdf:resource="#rd_task_status_field"/>
        <fields rdf:resource="#task_name_field"/>
        <fields rdf:resource="#task_desc_field"/>
        <fields rdf:resource="#handle_desc_field"/>
        <fields rdf:resource="#initiate_time_field"/>
        <fields rdf:resource="#plan_finish_time_field"/>
        <fields rdf:resource="#actual_finish_time_field"/>
        <fields rdf:resource="#create_by_field"/>
        <fields rdf:resource="#create_time_field"/>
        <fields rdf:resource="#update_by_field"/>
        <fields rdf:resource="#update_time_field"/>
        <fields rdf:resource="#remark_field"/>
        <action_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">["create_by_rd_task","update_by_rd_task","delete_by_rd_task"]</action_refs>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;rel_by_rd_task_to_po_users_initiator&quot;, &quot;rel_by_rd_task_to_po_users_handler&quot;]</relations>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#id_field">
        <rdf:type rdf:resource="#EntityField"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">id</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">主键</property_name>
