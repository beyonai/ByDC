        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">org_id</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">po_organization</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">org_id</source_column_code>
        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">byai_platform</source_datasource_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{"property_role_rule": {"property_role": "DIMENSION", "rule_type": "id"}}</ext_property>
    </owl:NamedIndividual>

