         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#po_organization_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">po_organization</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">组织信息表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">平台组织维度对象，承载客户、商机、项目所属组织及组织层级信息。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#org_id_mapping"/>
        <mapping rdf:resource="#org_code_mapping"/>
        <mapping rdf:resource="#org_name_mapping"/>
        <mapping rdf:resource="#org_type_mapping"/>
        <mapping rdf:resource="#parent_org_id_mapping"/>
        <mapping rdf:resource="#org_level_mapping"/>
        <mapping rdf:resource="#org_index_mapping"/>
        <mapping rdf:resource="#create_date_mapping"/>
        <mapping rdf:resource="#update_date_mapping"/>
        <mapping rdf:resource="#path_code_mapping"/>
        <mapping rdf:resource="#org_desc_mapping"/>
    </owl:NamedIndividual>

