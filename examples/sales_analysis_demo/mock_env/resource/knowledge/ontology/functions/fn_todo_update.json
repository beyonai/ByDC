{
  "function_code": "fn_todo_update",
  "function_name": "修改待办",
  "description": "修改待办事项的基本信息",
  "function_type": "API",
  "api_schema": {
    "openapi": "3.0.3",
    "info": {
      "title": "修改待办",
      "version": "1.0.0"
    },
    "servers": [
      {
        "url": "http://127.0.0.1:8001"
      }
    ],
    "paths": {
      "/api/v1/todos/update": {
        "post": {
          "summary": "修改待办",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "planFinishTime": {
                      "type": "string",
                      "description": "计划完成时间，格式 yyyy-MM-dd HH:mm:ss"
                    },
                    "handlerIds": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "处理人"
                    },
                    "priority": {
                      "type": "string",
                      "description": "优先级"
                    },
                    "urgencyLevel": {
                      "type": "string",
                      "description": "紧急程度"
                    },
                    "content": {
                      "type": "string",
                      "description": "待办内容"
                    },
                    "todoId": {
                      "type": "string",
                      "description": "待办ID"
                    }
                  },
                  "required": [
                    "todoId"
                  ]
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "修改结果",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "todoId": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}