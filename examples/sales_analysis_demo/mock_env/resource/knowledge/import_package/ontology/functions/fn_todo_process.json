{
  "function_code": "fn_todo_process",
  "function_name": "处理待办",
  "description": "批量处理待办事项，更新处理意见和进度",
  "function_type": "API",
  "api_schema": {
    "openapi": "3.0.3",
    "info": {
      "title": "处理待办",
      "version": "1.0.0"
    },
    "servers": [
      {
        "url": "http://127.0.0.1:8001"
      }
    ],
    "paths": {
      "/api/v1/todos/batch/process": {
        "post": {
          "summary": "批量处理待办",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "todoIds": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "待办ID列表"
                    },
                    "handleComment": {
                      "type": "string",
                      "description": "处理意见/备注"
                    },
                    "progress": {
                      "type": "integer",
                      "description": "处理进度 0-100",
                      "minimum": 0,
                      "maximum": 100
                    }
                  },
                  "required": [
                    "todoIds"
                  ]
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "处理结果",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "todoId": {
                        "type": "string",
                        "description": "被处理的待办ID"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}