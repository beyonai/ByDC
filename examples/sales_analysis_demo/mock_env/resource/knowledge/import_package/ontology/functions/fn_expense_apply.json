{
  "function_code": "fn_expense_apply",
  "function_name": "申请费用报备",
  "description": "创建费用报备记录",
  "function_type": "API",
  "api_schema": {
    "openapi": "3.0.3",
    "info": {
      "title": "申请费用报备",
      "version": "1.0.0"
    },
    "servers": [
      {
        "url": "http://127.0.0.1:8001"
      }
    ],
    "paths": {
      "/api/v1/expense-reports": {
        "post": {
          "summary": "申请费用报备",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "applicantEmpNo",
                    "applicantName",
                    "applicantOrgId",
                    "expenseAmount"
                  ],
                  "properties": {
                    "applicantEmpNo": {
                      "type": "string",
                      "description": "申请人工号或名称"
                    },
                    "applicantName": {
                      "type": "string",
                      "description": "申请人姓名"
                    },
                    "applicantOrgId": {
                      "type": "string",
                      "description": "申请组织ID"
                    },
                    "expenseAmount": {
                      "type": "number",
                      "description": "申请金额（元）"
                    },
                    "expenseDesc": {
                      "type": "string",
                      "description": "申请说明"
                    },
                    "relatedBoId": {
                      "type": "string",
                      "description": "关联商机ID"
                    },
                    "relatedCustomerId": {
                      "type": "string",
                      "description": "关联客户ID"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "创建结果",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "errorMsg": {
                        "type": "string"
                      },
                      "status": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}