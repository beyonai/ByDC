{
  "function_code": "fn_todo_create",
  "function_name": "创建待办",
  "description": "创建待办事项并指定处理人",
  "function_type": "API",
  "api_schema": {
    "openapi": "3.0.3",
    "info": {
      "title": "创建待办",
      "version": "1.0.0"
    },
    "servers": [
      {
        "url": "http://127.0.0.1:8001"
      }
    ],
    "paths": {
      "/api/v1/todos": {
        "post": {
          "summary": "创建待办",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "title"
                  ],
                  "properties": {
                    "title": {
                      "type": "string",
                      "description": "待办标题"
                    },
                    "deadlineAt": {
                      "type": "string",
                      "description": "截止时间，格式 yyyy-MM-dd HH:mm:ss"
                    },
                    "handlerIds": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "处理人ID列表"
                    },
                    "priority": {
                      "type": "string",
                      "description": "优先级"
                    },
                    "urgencyLevel": {
                      "type": "string",
                      "description": "紧急程度"
                    },
                    "content": {
                      "type": "string",
                      "description": "待办内容"
                    },
                    "meetingNoteId": {
                      "type": "string",
                      "description": "关联的会议纪要id"
                    },
                    "promoter": {
                      "type": "string",
                      "description": "单据人/发起人名称或员工工号"
                    },
                    "remark": {
                      "type": "string",
                      "description": "备注"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "创建结果",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "todoId": {
                        "type": "string"
                      },
                      "errorMsg": {
                        "type": "string"
                      },
                      "status": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      },
                      "createdAt": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}