{
  "function_code": "fn_po_users_query_by_org",
  "function_name": "按组织ID查询人员",
  "description": "按组织ID查询该组织下的人员列表",
  "function_type": "API",
  "api_schema": {
    "openapi": "3.0.3",
    "info": {
      "title": "按组织ID查询人员",
      "version": "1.0.0"
    },
    "servers": [
      {
        "url": "http://127.0.0.1:8001"
      }
    ],
    "paths": {
      "/api/v1/po/users/by-org": {
        "post": {
          "summary": "按组织ID查询人员",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orgId": {
                      "type": "string",
                      "description": "组织ID"
                    },
                    "includeSubOrgs": {
                      "type": "boolean",
                      "description": "是否包含下级组织人员"
                    }
                  },
                  "required": [
                    "orgId"
                  ]
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "人员列表",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "users": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "userId": {
                              "type": "string",
                              "description": "用户ID"
                            },
                            "userName": {
                              "type": "string",
                              "description": "用户名称"
                            },
                            "userNumber": {
                              "type": "string",
                              "description": "工号"
                            },
                            "orgId": {
                              "type": "string",
                              "description": "组织ID"
                            },
                            "state": {
                              "type": "string",
                              "description": "用户状态"
                            },
                            "email": {
                              "type": "string",
                              "description": "用户邮箱"
                            },
                            "phone": {
                              "type": "string",
                              "description": "用户电话"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}