{
  "function_code": "fn_todo_urge",
  "function_name": "催更待办",
  "description": "批量催更待办事项进度",
  "function_type": "API",
  "api_schema": {
    "openapi": "3.0.3",
    "info": {
      "title": "催更待办",
      "version": "1.0.0"
    },
    "servers": [
      {
        "url": "http://127.0.0.1:8001"
      }
    ],
    "paths": {
      "/api/v1/todos/batch/urge": {
        "post": {
          "summary": "批量催更待办",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "todoIds"
                  ],
                  "properties": {
                    "todoIds": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "待办ID列表"
                    },
                    "followUpContent": {
                      "type": "string",
                      "description": "催更内容"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "催更结果",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "todoId": {
                        "type": "string"
                      },
                      "followUpAt": {
                        "type": "string",
                        "description": "催更时间，格式 YYYY-MM-DD HH:mm:ss"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}