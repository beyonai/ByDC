{
  "function_code": "fn_po_users_query_by_ids",
  "function_name": "按名称/ID查询人员",
  "description": "按用户ID或姓名列表批量查询人员详情",
  "function_type": "API",
  "api_schema": {
    "openapi": "3.0.3",
    "info": {
      "title": "按名称/ID查询人员",
      "version": "1.0.0"
    },
    "servers": [
      {
        "url": "http://127.0.0.1:8001"
      }
    ],
    "paths": {
      "/api/v1/po/users/query": {
        "post": {
          "summary": "按用户ID或名称查询人员",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "userIds": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "用户ID列表（与names二选一）"
                    },
                    "names": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "用户名称列表（与userIds二选一）"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "人员列表",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "users": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "userId": {
                              "type": "string"
                            },
                            "userName": {
                              "type": "string"
                            },
                            "userNumber": {
                              "type": "string"
                            },
                            "orgId": {
                              "type": "string"
                            },
                            "state": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}