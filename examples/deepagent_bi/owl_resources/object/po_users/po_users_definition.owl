    <owl:NamedIndividual rdf:about="#po_users_v1">
        <rdf:type rdf:resource="#EntityDefinition"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">po_users</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">用户信息表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">平台用户维度对象，承载销售、发起人、处理人等人员信息。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <entity_source rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DB</entity_source>
        <fields rdf:resource="#user_id_field"/>
        <fields rdf:resource="#user_name_field"/>
        <fields rdf:resource="#email_field"/>
        <fields rdf:resource="#phone_field"/>
        <fields rdf:resource="#user_code_field"/>
        <fields rdf:resource="#pwd_field"/>
        <fields rdf:resource="#address_field"/>
        <fields rdf:resource="#remark_field"/>
        <fields rdf:resource="#user_eff_date_field"/>
        <fields rdf:resource="#user_exp_date_field"/>
        <fields rdf:resource="#create_date_field"/>
        <fields rdf:resource="#update_date_field"/>
        <fields rdf:resource="#state_field"/>
        <fields rdf:resource="#state_time_field"/>
        <fields rdf:resource="#is_locked_field"/>
        <fields rdf:resource="#last_login_date_field"/>
        <fields rdf:resource="#security_question_id_field"/>
        <fields rdf:resource="#security_answer_field"/>
        <fields rdf:resource="#thumbnail_uri_field"/>
        <fields rdf:resource="#ext_attr_field"/>
        <fields rdf:resource="#assistant_id_field"/>
        <fields rdf:resource="#user_number_field"/>
        <fields rdf:resource="#station_id_field"/>
        <fields rdf:resource="#register_type_field"/>
        <fields rdf:resource="#apple_user_id_field"/>
        <action_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;query_po_users&quot;]</action_refs>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[]</relations>
    </owl:NamedIndividual>

