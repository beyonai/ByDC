        <request_url rdf:datatype="http://www.w3.org/2001/XMLSchema#string">http://10.10.168.203:8999/api/by/customer/add</request_url>
        <request_method rdf:datatype="http://www.w3.org/2001/XMLSchema#string">POST</request_method>
        <script rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></script>
