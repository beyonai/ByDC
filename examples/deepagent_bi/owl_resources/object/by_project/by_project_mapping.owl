<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xml:base="http://example.org/entity/mapping#">

    <owl:Class rdf:about="#EntityMapping"><rdfs:label>实体映射</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Mapping"><rdfs:label>映射关系</rdfs:label></owl:Class>

    <owl:NamedIndividual rdf:about="#by_project_mapping">
        <rdf:type rdf:resource="#EntityMapping"/>
        <entity_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_project</entity_code>
        <entity_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">项目信息表</entity_name>
        <entity_desc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">项目履约对象，承载客户、关联商机、项目状态、合同、收入、回款、欠费和计划/实际月份。</entity_desc>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <mapping rdf:resource="#id_mapping"/>
        <mapping rdf:resource="#project_code_mapping"/>
        <mapping rdf:resource="#project_name_mapping"/>
        <mapping rdf:resource="#industry_mapping"/>
        <mapping rdf:resource="#domain_mapping"/>
        <mapping rdf:resource="#customer_code_mapping"/>
        <mapping rdf:resource="#sales_user_id_mapping"/>
        <mapping rdf:resource="#dept_id_mapping"/>
        <mapping rdf:resource="#opp_id_mapping"/>
        <mapping rdf:resource="#product_code_mapping"/>
        <mapping rdf:resource="#project_status_mapping"/>
        <mapping rdf:resource="#contract_amount_mapping"/>
        <mapping rdf:resource="#revenue_amount_mapping"/>
        <mapping rdf:resource="#payment_amount_mapping"/>
        <mapping rdf:resource="#arrear_amount_mapping"/>
        <mapping rdf:resource="#plan_online_date_mapping"/>
        <mapping rdf:resource="#actual_online_date_mapping"/>
        <mapping rdf:resource="#plan_revenue_date_mapping"/>
        <mapping rdf:resource="#actual_revenue_date_mapping"/>
        <mapping rdf:resource="#plan_payment_date_mapping"/>
        <mapping rdf:resource="#actual_payment_date_mapping"/>
        <mapping rdf:resource="#create_by_mapping"/>
        <mapping rdf:resource="#create_time_mapping"/>
        <mapping rdf:resource="#update_by_mapping"/>
        <mapping rdf:resource="#update_time_mapping"/>
        <mapping rdf:resource="#remark_mapping"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#id_mapping">
        <rdf:type rdf:resource="#Mapping"/>
        <property_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">id</property_code>
        <property_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">主键</property_name>
        <source_table_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">by_project</source_table_code>
        <source_column_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">id</source_column_code>
        <source_datasource_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">wukong_crm_demo</source_datasource_code>
        <ext_property rdf:datatype="http://www.w3.org/2001/XMLSchema#string">{"property_role_rule": {"property_role": "MEASURE", "rule_type": "primary_key"}}</ext_property>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#project_code_mapping">
