        <fields rdf:resource="#org_desc_field"/>
        <action_refs rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;query_po_organization&quot;]</action_refs>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;rel_po_organization_to_parent&quot;]</relations>
    </owl:NamedIndividual>

