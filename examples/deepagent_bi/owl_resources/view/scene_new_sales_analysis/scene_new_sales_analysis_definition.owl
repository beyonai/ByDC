    <owl:NamedIndividual rdf:about="#scene_new_sales_analysis_v1">
        <rdf:type rdf:resource="#SceneDefinition"/>
        <view_code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">scene_new_sales_analysis</view_code>
        <view_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">复合肥销售分析视图</view_name>
        <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">以复合肥销量宽表为主对象，关联订单明细，用于按月份、省份、销售人员和产品配方分析销量。</description>
        <version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</version>
        <object_codes rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;dwd_ai_yx_compound_fertilizer_sales_df_demo&quot;, &quot;order_details&quot;]</object_codes>
        <relations rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[&quot;rel_scene_new_sales_analysis_to_dwd_ai_yx_compound_fertilizer_sales_df_demo&quot;, &quot;rel_scene_new_sales_analysis_to_order_details&quot;, &quot;rel_sales_wide_to_order_details_by_province_day&quot;]</relations>
        <fields rdf:resource="#day_field"/>
        <fields rdf:resource="#month_field"/>
        <fields rdf:resource="#year_field"/>
        <fields rdf:resource="#province_field"/>
        <fields rdf:resource="#city_field"/>
        <fields rdf:resource="#county_field"/>
        <fields rdf:resource="#theater_field"/>
        <fields rdf:resource="#sub_theater_field"/>
        <fields rdf:resource="#regional_market_field"/>
        <fields rdf:resource="#base_field"/>
        <fields rdf:resource="#product_pro_line_field"/>
        <fields rdf:resource="#sales_volume_field"/>
        <fields rdf:resource="#order_no_field"/>
        <fields rdf:resource="#customer_name_field"/>
        <fields rdf:resource="#staff_name_field"/>
        <fields rdf:resource="#formula_field"/>
        <fields rdf:resource="#order_sales_volume_field"/>
        <fields rdf:resource="#create_time_field"/>
    </owl:NamedIndividual>

